---
import Base from '../layouts/Base.astro';
import { fetchAPI, mediaUrl, mediaUrls } from '../lib/strapi.js';

// ===========================================================================
// Données dynamiques (Strapi) AVEC REPLI sur du contenu de démo.
// Si Strapi est vide / indisponible / non autorisé -> on affiche le statique,
// donc la page reste toujours présentable. Dès qu'on saisit du contenu dans
// le back-office (+ permissions Public), il remplace automatiquement le repli.
// ===========================================================================
const catLabel = { fiction: 'Fiction', documentaire: 'Documentaire', animation: 'Animation', 'court-metrage': 'Court-métrage' };
const typeLabel = { projection: 'Projection', masterclass: 'Masterclass', rencontre: 'Rencontre', ceremonie: 'Cérémonie' };

// --- Édition courante (pour le compte à rebours) ---
const edRes = await fetchAPI('editions', { 'filters[isCurrent][$eq]': 'true', 'pagination[limit]': '1' });
const edition = (edRes.data || [])[0] || null;
// On utilise la date de l'édition seulement si elle est dans le futur (sinon repli).
const festivalTarget =
  edition?.dateStart && new Date(edition.dateStart) > new Date()
    ? `${edition.dateStart}T19:00:00`
    : '2027-11-17T19:00:00';

// Vidéo (Vimeo) — depuis l'Édition (champ videoUrl) ou repli sur la vidéo 2025 fournie.
function toEmbed(url) {
  if (!url) return null;
  const m = String(url).match(/vimeo\.com\/(\d+)(?:\/(\w+))?/);
  if (m) return `https://player.vimeo.com/video/${m[1]}${m[2] ? `?h=${m[2]}` : ''}`;
  return url;
}
const videoEmbed = toEmbed(edition?.videoUrl) || 'https://player.vimeo.com/video/1169196245?h=5c5f7be273';

// --- Films à l'affiche ---
const filmRes = await fetchAPI('films', { populate: 'poster', sort: 'year:desc', 'pagination[limit]': '6' });
const cmsFilms = filmRes.data || [];
const fallbackFilms = [
  { title: 'Sous le Baobab', cat: 'Fiction', meta: 'Aïssatou Diop · Sénégal · 2025', poster: null },
  { title: 'Voix de Casamance', cat: 'Documentaire', meta: 'Mamadou Ba · 88 min', poster: null },
  { title: "L'Esprit du Fleuve", cat: 'Animation', meta: 'Studio Téranga · 2027', poster: null },
  { title: 'Le Dernier Griot', cat: 'Fiction', meta: 'Fatou Sow · Mali', poster: null },
  { title: 'Nuit à Ziguinchor', cat: 'Court-métrage', meta: 'O. Diédhiou · 18 min', poster: null },
  { title: "Mémoires d'Afrique", cat: 'Documentaire', meta: 'Collectif Casamance', poster: null },
];
// Contenu CMS d'abord, complété par des placeholders pour ne jamais paraître vide.
const films = [
  ...cmsFilms.map((f) => ({
    title: f.title,
    cat: catLabel[f.category] || f.category || 'Film',
    meta: [f.director, f.country, f.year].filter(Boolean).join(' · '),
    poster: f.poster?.url ? mediaUrl(f.poster.url) : null,
  })),
  ...fallbackFilms,
].slice(0, 6);

// --- Programme (temps forts) ---
const evRes = await fetchAPI('programme-events', { sort: 'day:asc', 'pagination[limit]': '4' });
const cmsEvents = evRes.data || [];
const fallbackEvents = [
  { time: 'Mer 17', type: 'ceremonie', title: "Cérémonie d'ouverture & film inaugural", desc: "Le coup d'envoi du festival, en présence des invités.", place: 'Théâtre Aline Sitoé Diatta' },
  { time: 'Jeu 18', type: 'projection', title: 'Projections en compétition', desc: 'Fictions, documentaires et animations de la sélection.', place: 'Salle Casamance' },
  { time: 'Ven 19', type: 'masterclass', title: 'Masterclasses & rencontres pro', desc: 'Transmission avec les cinéastes invités.', place: 'Institut français' },
  { time: 'Sam 20', type: 'ceremonie', title: 'Cérémonie de clôture & palmarès', desc: "Remise des prix de l'édition 2027.", place: 'Théâtre Aline Sitoé Diatta' },
];
const events = [
  ...cmsEvents.map((e) => ({
    time: e.startTime || (e.day ? `Jour ${e.day}` : '—'),
    type: e.type || 'projection',
    title: e.title,
    desc: e.description || '',
    place: e.location || '',
  })),
  ...fallbackEvents,
].slice(0, 4);

// --- Galerie / pellicule ---
const photoRes = await fetchAPI('photos', { populate: 'image', 'pagination[limit]': '12' });
const cmsPhotos = (photoRes.data || []).flatMap((p) => mediaUrls(p.image));
const fallbackPhotos = Array.from({ length: 10 }, (_, i) => `/photos/photo${String(i + 1).padStart(2, '0')}.jpg`);
const stripUrls = [...cmsPhotos, ...fallbackPhotos].slice(0, 10);

// --- Partenaires ---
const partRes = await fetchAPI('partners', { populate: 'logo', sort: 'order:asc' });
const cmsPartners = partRes.data || [];
const fallbackPartners = [
  { name: 'Wallonie-Bruxelles Int.', url: 'https://www.wbi.be', logo: '/partenaires/wallonie-bruxelles.jpg' },
  { name: 'Alliance Française', url: '#', logo: '/partenaires/alliance-francaise.jpg' },
  { name: 'Air Sénégal', url: 'https://flyairsenegal.com', logo: '/partenaires/air-senegal.jpg' },
  { name: 'FOTTI', url: '#', logo: '/partenaires/fotti.jpg' },
  { name: 'LONASE', url: 'https://www.lonase.sn', logo: '/partenaires/lonase.jpg' },
  { name: 'TALAATA Production', url: '#', logo: '/partenaires/talaata.jpg' },
];
const cmsPartnersMapped = cmsPartners.map((p) => ({ name: p.name, url: p.url || '#', logo: p.logo?.url ? mediaUrl(p.logo.url) : null }));
// Strapi seul dès qu'il y a au moins 1 partenaire ; sinon logos de démo.
const partners = cmsPartnersMapped.length ? cmsPartnersMapped : fallbackPartners;

// --- Mosaïque du hero ---
const shapes = ['tall', 'square', 'wide'];
const heroCols = Array.from({ length: 6 }, (_, c) =>
  Array.from({ length: 10 }, (_, i) => ({
    n: String(((c * 3 + i * 2) % 10) + 1).padStart(2, '0'),
    shape: shapes[(c + i) % 3],
  }))
);
---
<Base
  title="ZIFFA 2027 — Ziguinchor International Film Festival & Animation"
  description="Le rendez-vous du cinéma africain en Casamance — 12 au 15 novembre 2027."
>
  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero-mosaic">
      {heroCols.map((cards, idx) => (
        <div class={`mosaic-col mosaic-col-${idx + 1}`}>
          {cards.map((card) => (
            <div class={`mosaic-card ${card.shape}`}><img src={`/photos/photo${card.n}.jpg`} alt="" /></div>
          ))}
        </div>
      ))}
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <h1 class="hero-acronym">ZIFFA<span class="red-dot">.</span></h1>
      <div class="hero-full-name">
        <strong>Z</strong>iguinchor &nbsp;·&nbsp; <strong>I</strong>nternational &nbsp;·&nbsp;
        <strong>F</strong>ilm &nbsp;·&nbsp; <strong>F</strong>estival &nbsp;·&nbsp; <strong>&amp; A</strong>nimation
      </div>
      <h2 class="hero-subtitle">
        Le premier festival international de cinéma<br />
        et d'animation en <span class="yellow">Casamance</span>.
      </h2>
      <div class="hero-disciplines">
        <span class="discipline-pill">Long métrage</span>
        <span class="discipline-pill">Court métrage</span>
        <span class="discipline-pill">Animation</span>
        <span class="discipline-pill">Photographie</span>
      </div>
      <div class="hero-actions">
        <a href="/edition-2027" class="btn-primary">Découvrir l'édition 2027 →</a>
        <a href="/participer#inscription" class="btn-ghost">▶ Inscrire un film</a>
      </div>
    </div>
  </section>

  <!-- ===== 2. PROCHAINE ÉDITION ===== -->
  <section class="countdown-section">
    <div class="countdown-inner">
      <div class="eyebrow"><span class="arrow">→</span> Prochaine édition · Ziguinchor</div>
      <h2 class="section-title">Rendez-vous en <span class="yellow">2027</span>.</h2>
    </div>
  </section>

  <!-- ===== 3. LE FESTIVAL EN BREF ===== -->
  <section class="section">
    <div class="festival-split">
      <div class="festival-text">
        <div class="eyebrow"><span class="arrow">→</span> Le festival</div>
        <h2 class="section-title">Le cinéma africain,<br /><span class="red">en Casamance</span>.</h2>
        <p class="lead">Le ZIFFA célèbre la création cinématographique et l'animation du continent et de sa diaspora : quatre jours de projections, de rencontres et de transmission, ouverts à tous.</p>
        <a href="/le-ziffa" class="nav-cta">Découvrir le festival ↗</a>
      </div>
      <div class="festival-stats">
        <div class="fstat fstat-red"><div class="fstat-num" data-count="4"><span class="fstat-val">4</span><span class="fstat-suffix">j</span></div><div class="fstat-label">de festival</div></div>
        <div class="fstat fstat-green"><div class="fstat-num" data-count="25"><span class="fstat-val">25</span></div><div class="fstat-label">films projetés</div></div>
        <div class="fstat fstat-yellow"><div class="fstat-num" data-count="10"><span class="fstat-val">10</span><span class="fstat-suffix">+</span></div><div class="fstat-label">pays représentés</div></div>
      </div>
    </div>
  </section>

  {/* ===== 4. À L'AFFICHE — masqué en attendant la sélection officielle =====
  <section class="section" style="padding-top:0;">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="arrow">→</span> Sélection officielle</div>
        <h2 class="section-title">À l'<span class="italic">affiche</span>.</h2>
      </div>
      <a href="/edition-2027" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Toute la sélection →</a>
    </div>
    <div class="film-grid">
      {films.map((f) => (
        <article class="film-card">
          <div class="film-poster" style={f.poster ? `background-image:url('${f.poster}');background-size:cover;background-position:center;` : ''}>
            <span class="film-cat">{f.cat}</span>
          </div>
          <div class="film-body">
            <h3 class="film-title">{f.title}</h3>
            <div class="film-meta">{f.meta}</div>
          </div>
        </article>
      ))}
    </div>
  </section>
  */}

  {/* Programme masqué sur l'accueil — sera réactivé quand le vrai programme sera dans Strapi */}

  <!-- ===== 6. TEASER OFFICIEL ===== -->
  <section class="teaser-section">
    <div class="teaser-inner">
      <div class="teaser-head">
        <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Teaser officiel</div>
        <h2 class="section-title">ZIFFA <span class="red">2027</span> en <span class="italic">mouvement</span>.</h2>
        <p>Un avant-goût du festival : l'énergie, les images, l'émotion du cinéma africain.</p>
      </div>
      <div class="teaser-player" id="teaser-player" data-embed={videoEmbed} role="button" tabindex="0" aria-label="Lire la bande-annonce ZIFFA">
        <div class="teaser-poster"><span class="teaser-mark">ZIFFA · 2027</span></div>
        <div class="teaser-play"><span>▶</span></div>
        <div class="teaser-cta">Regarder la bande-annonce</div>
      </div>
    </div>
  </section>

  <!-- ===== 7. GALERIE / PELLICULE ===== -->
  <section class="filmstrip-section">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="arrow">→</span> En images</div>
        <h2 class="section-title">Une fête du <span class="red">cinéma</span>.</h2>
      </div>
      <a href="/edition-2025#images" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Toute la galerie →</a>
    </div>
    <div class="filmstrip">
      <div class="filmstrip-track">
        {stripUrls.map((url) => (<figure><img src={url} alt="ZIFFA — temps fort" loading="lazy" /></figure>))}
        {stripUrls.map((url) => (<figure aria-hidden="true"><img src={url} alt="" loading="lazy" /></figure>))}
      </div>
    </div>
  </section>

  <!-- ===== 8. PARTENAIRES ===== -->
  <section class="partners-section" id="partenaires">
    <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Soutiens & Partenaires</div>
    <h2 class="section-title" style="margin:16px auto 0;max-width:700px;">Ils <span class="red">accompagnent</span><br />le ZIFFA.</h2>
    <p class="partners-intro">Le festival est rendu possible grâce au soutien d'institutions et de partenaires engagés pour le cinéma africain.</p>
    <div class="partners-marquee">
      <div class="partners-marquee-track">
        {partners.map((p) => (
          <a href={p.url} target="_blank" rel="noopener" class="partner-logo" title={p.name}>
            {p.logo && <img src={p.logo} alt={p.name} />}
            <span class="partner-logo-name">{p.name}</span>
          </a>
        ))}
        {partners.map((p) => (
          <a href={p.url} target="_blank" rel="noopener" class="partner-logo" title={p.name} aria-hidden="true" tabindex="-1">
            {p.logo && <img src={p.logo} alt="" />}
            <span class="partner-logo-name">{p.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 9. NEWSLETTER ===== -->
  <section class="newsletter" id="newsletter">
    <div class="newsletter-inner">
      <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Newsletter</div>
      <h2>Ne ratez <span class="red">rien</span><br />du <span class="italic">festival</span>.</h2>
      <p>Programmes, appels à films, annonces de jurys, coulisses : recevez l'actualité du ZIFFA dans votre boîte mail.</p>
      <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Merci pour votre inscription !'); this.reset();">
        <input type="email" placeholder="votre@email.com" required />
        <button type="submit">S'inscrire ↗</button>
      </form>
    </div>
  </section>
</Base>

<script>
  const tp = document.getElementById('teaser-player');
  if (tp) {
    const play = () => {
      if (tp.classList.contains('playing')) return;
      const base = tp.dataset.embed;
      const src = base + (base.includes('?') ? '&' : '?') + 'autoplay=1';
      tp.innerHTML = '<iframe src="' + src + '" title="ZIFFA — bande-annonce" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="width:100%;height:100%;border:0;display:block;"></iframe>';
      tp.classList.add('playing');
    };
    tp.addEventListener('click', play);
    tp.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); play(); } });
  }

  // Compteurs animés des stats « Le festival »
  const stats = document.querySelector('.festival-stats');
  if (stats) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const run = () => {
      stats.querySelectorAll('.fstat-num').forEach((el) => {
        const val = el.querySelector('.fstat-val');
        const target = parseInt(el.dataset.count, 10) || 0;
        if (reduce) { val.textContent = String(target); return; }
        const dur = 1100; const t0 = performance.now();
        val.textContent = '0';
        const step = (now) => {
          const p = Math.min(1, (now - t0) / dur);
          const eased = 1 - Math.pow(1 - p, 3);
          val.textContent = String(Math.round(eased * target));
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      });
    };
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { run(); io.disconnect(); } });
      }, { threshold: 0.4 });
      io.observe(stats);
    } else { run(); }
  }
</script>
