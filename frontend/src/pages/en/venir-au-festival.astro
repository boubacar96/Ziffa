---
import Base from '../../layouts/Base.astro';

const venues = [
  { n: 1, name: 'Mémorial du bateau le Joola', role: 'Ceremonies & tributes', icon: '🕯️', hex: '#D63832', lat: 12.5688, lng: -16.2742 },
  { n: 2, name: 'Centre Culturel Régional', role: 'Screenings & talks', icon: '🏛️', hex: '#2A6B3F', lat: 12.5656892, lng: -16.2673909 },
  { n: 3, name: 'U.F.R Santé — Assane Seck University', role: 'Festival HQ', icon: '🎓', hex: '#F2B718', lat: 12.5494994, lng: -16.2830714 },
  { n: 4, name: 'Place Bambaya', role: 'Open-air screening', icon: '🎪', hex: '#2A6B3F', lat: 12.5746631, lng: -16.2850057 },
];

const travel = [
  { color: 'red', icon: '✈️', title: 'By plane', text: "Flights <strong>Dakar → Ziguinchor</strong> (≈ 1 h) with Air Sénégal. The airport is 10 min from the city centre." },
  { color: 'green', icon: '🚗', title: 'By road', text: "≈ 450 km from Dakar (≈ 7–8 h) via the Trans-Gambia Highway. Buses, shared cars and rentals connect the two cities." },
  { color: 'yellow', icon: '⛴️', title: 'By boat', text: "The <strong>Aline Sitoé Diatta</strong> ferry links Dakar to Ziguinchor (≈ 15 h) — an iconic coastal crossing to experience at least once." },
];

const infos = [
  { icon: '🌤️', title: 'Climate', text: 'November: warm and sunny. Pack light clothing.' },
  { icon: '💶', title: 'Currency', text: 'CFA Franc (FCFA). Cash recommended; ATMs in town.' },
  { icon: '🗣️', title: 'Languages', text: 'French, Wolof and Diola. Warm, friendly welcome.' },
  { icon: '🎟️', title: 'Access', text: 'Free screenings subject to available seats. Pro accreditation via the Contact page.' },
];
---
<Base title="Come to the festival | ZIFFA" description="Coming to ZIFFA in Ziguinchor: dates, venues, how to get there (plane, road, boat) and practical info.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; Take part &nbsp;/&nbsp; Come to the festival</div>
      <div class="eyebrow"><span class="arrow">→</span> Practical info</div>
      <h1>Come to the <span class="yellow">festival</span>.</h1>
      <p>Everything to plan your trip to Ziguinchor, in the heart of Casamance.</p>
    </div>
  </header>

  <section class="section" id="lieux">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> When &amp; where</div><h2 class="section-title">The <span class="red">venues</span>.</h2></div></div>
    <p class="lead" style="max-width:760px;margin-bottom:24px;">The festival takes place across several venues in Ziguinchor. Click a venue to locate it on the map:</p>
    <div class="zmap">
      <div class="zmap-canvas">
        <div id="ziffa-map" role="application" aria-label="Map of the festival venues in Ziguinchor"></div>
        <button id="zmap-reset" class="zmap-reset" type="button">⤢ Overview</button>
      </div>
      <div class="zmap-aside">
        {venues.map((v) => (
          <button class="zmap-card" data-i={v.n - 1} style={`--vc:${v.hex}`} type="button">
            <span class="zmap-num">{v.n}</span>
            <span class="zmap-ic">{v.icon}</span>
            <span class="zmap-txt"><strong>{v.name}</strong><em>{v.role}</em></span>
            <span class="zmap-go">→</span>
          </button>
        ))}
        <p class="zmap-hint">Tip: click a marker to get Google Maps directions.</p>
      </div>
    </div>
  </section>

  <section class="section" id="comment-venir">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Getting there</div><h2 class="section-title">How to <span class="red">arrive</span>.</h2></div></div>
    <div class="presse-cards">
      {travel.map((m) => (
        <div class={`presse-card pc-${m.color}`}>
          <span class="presse-ic">{m.icon}</span>
          <h3>{m.title}</h3>
          <p set:html={m.text}></p>
        </div>
      ))}
    </div>
  </section>

  <section class="section" id="sejour">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> On site</div><h2 class="section-title">Your <span class="red">stay</span>.</h2></div></div>
    <div class="presentation-editorial" style="max-width:820px;">
      <p><strong>Where to stay?</strong> Ziguinchor offers hotels, guesthouses and B&Bs, from the city centre to the banks of the Casamance river. Be sure to <strong>book early</strong> during the festival.</p>
      <p><strong>Getting around.</strong> The central venues (Mémorial du Joola, Regional Cultural Centre, Place Bambaya) are ~5 min apart on foot; Assane Seck University (U.F.R Santé) is ~10 min by minibus. Taxis and moto-taxis (“Jakarta”) complete the picture.</p>
      <p><strong>Atmosphere.</strong> Between screenings, enjoy Casamance cuisine, the markets and the warmth of Ziguinchor's welcome.</p>
    </div>
  </section>

  <section class="section" id="infos">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Good to know</div><h2 class="section-title">Practical <span class="red">info</span>.</h2></div></div>
    <div class="presse-cards">
      {infos.map((m) => (
        <div class="presse-card pc-green">
          <span class="presse-ic">{m.icon}</span>
          <h3>{m.title}</h3>
          <p>{m.text}</p>
        </div>
      ))}
    </div>
    <div style="margin-top:34px;"><a href="/en/contact#contact" class="nav-cta">A question? Contact us ↗</a></div>
  </section>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script is:inline define:vars={{ venues }}>
    (function () {
      if (!window.L) return;
      const el = document.getElementById('ziffa-map');
      if (!el) return;
      const map = L.map(el, { scrollWheelZoom: false, zoomControl: true });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        maxZoom: 19, subdomains: 'abcd', attribution: '&copy; OpenStreetMap, &copy; CARTO',
      }).addTo(map);

      const markers = [], pts = [];
      const dirUrl = (name) => 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(name + ' Ziguinchor');

      venues.forEach(function (v, i) {
        const icon = L.divIcon({
          className: 'zpin-wrap',
          html: '<div class="zpin" style="--vc:' + v.hex + '"><span class="zpin-dot"><b>' + v.n + '</b></span></div>',
          iconSize: [38, 48], iconAnchor: [19, 46], popupAnchor: [0, -42],
        });
        const m = L.marker([v.lat, v.lng], { icon }).addTo(map);
        m.bindPopup(
          '<div class="zpop"><span class="zpop-role" style="color:' + v.hex + '">' + v.icon + ' ' + v.role + '</span>' +
          '<strong>' + v.name + '</strong>' +
          '<a href="' + dirUrl(v.name) + '" target="_blank" rel="noopener">Directions ↗</a></div>',
          { closeButton: false }
        );
        m.on('click', function () { select(i); });
        markers.push(m); pts.push([v.lat, v.lng]);
      });

      const bounds = L.latLngBounds(pts);

      function clearActive() {
        document.querySelectorAll('.zmap-card').forEach((c) => c.classList.remove('is-active'));
        document.querySelectorAll('.zpin-wrap').forEach((p) => p.classList.remove('is-active'));
      }
      function select(i) {
        clearActive();
        const v = venues[i];
        map.flyTo([v.lat, v.lng], 16, { duration: 0.8 });
        markers[i].openPopup();
        const card = document.querySelector('.zmap-card[data-i="' + i + '"]');
        if (card) card.classList.add('is-active');
        if (markers[i]._icon) markers[i]._icon.classList.add('is-active');
      }
      function overview() { clearActive(); map.flyToBounds(bounds, { padding: [50, 50], maxZoom: 15, duration: 0.8 }); }

      document.querySelectorAll('.zmap-card').forEach(function (card) {
        const i = parseInt(card.dataset.i, 10);
        card.addEventListener('click', function () { select(i); });
        card.addEventListener('mouseenter', function () { if (markers[i]._icon) markers[i]._icon.classList.add('is-hover'); });
        card.addEventListener('mouseleave', function () { if (markers[i]._icon) markers[i]._icon.classList.remove('is-hover'); });
      });
      const reset = document.getElementById('zmap-reset');
      if (reset) reset.addEventListener('click', overview);

      map.fitBounds(bounds, { padding: [50, 50], maxZoom: 15 });
      setTimeout(function () { map.invalidateSize(); }, 200);
    })();
  </script>
</Base>
