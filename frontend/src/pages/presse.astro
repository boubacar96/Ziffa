---
import Base from '../layouts/Base.astro';
import { PRESS_PARTS } from '../lib/press.js';
---
<Base title="Espace presse | ZIFFA" description="Espace presse du ZIFFA : dossier de presse, logos & charte graphique, photothèque officielle.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; <a href="/le-ziffa#presse">Le ZIFFA</a> &nbsp;/&nbsp; Presse</div>
      <div class="eyebrow"><span class="arrow">→</span> Espace presse</div>
      <h1>Espace <span class="yellow">presse</span>.</h1>
      <p>Choisissez une rubrique pour accéder à ses ressources officielles, à télécharger.</p>
    </div>
  </header>

  <section class="section">
    <div class="presse-cards">
      {PRESS_PARTS.map((p) => (
        <a class={`presse-card pc-${p.color}`} href={`/presse/${p.key}`}>
          <span class="presse-ic">{p.icon}</span>
          <h3>{p.fr.title}</h3>
          <p>{p.fr.desc}</p>
          <span class="presse-go">Accéder →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
