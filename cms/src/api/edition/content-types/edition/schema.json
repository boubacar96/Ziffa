{
  "kind": "collectionType",
  "collectionName": "editions",
  "info": {
    "singularName": "edition",
    "pluralName": "editions",
    "displayName": "Édition"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "year": {
      "type": "integer",
      "required": true,
      "unique": true
    },
    "number": {
      "type": "integer"
    },
    "title": {
      "type": "string"
    },
    "tagline": {
      "type": "text"
    },
    "dateStart": {
      "type": "date"
    },
    "dateEnd": {
      "type": "date"
    },
    "location": {
      "type": "string"
    },
    "isCurrent": {
      "type": "boolean",
      "default": false
    },
    "videoUrl": {
      "type": "string"
    },
    "poster": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "programmePdf": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    },
    "programmeDays": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::programme-day.programme-day",
      "mappedBy": "edition"
    },
    "films": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::film.film",
      "mappedBy": "edition"
    },
    "events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::programme-event.programme-event",
      "mappedBy": "edition"
    },
    "members": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::person.person",
      "mappedBy": "edition"
    },
    "prizes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::prize.prize",
      "mappedBy": "edition"
    },
    "photos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::photo.photo",
      "mappedBy": "edition"
    }
  }
}