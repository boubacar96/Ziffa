{
  "kind": "collectionType",
  "collectionName": "masterclasses",
  "info": {
    "singularName": "masterclass",
    "pluralName": "masterclasses",
    "displayName": "Masterclass"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "excerpt": {
      "type": "text"
    },
    "location": {
      "type": "string"
    },
    "participants": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "content": {
      "type": "richtext"
    },
    "quote": {
      "type": "text"
    },
    "quoteAuthor": {
      "type": "string"
    },
    "reportageUrl": {
      "type": "string"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "videos": {
      "type": "component",
      "repeatable": true,
      "component": "formation.video"
    },
    "speaker": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::person.person"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "edition": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::edition.edition"
    }
  }
}
