---
import Base from '../../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../../lib/strapi.js';

const VIDEO_2025 = 'https://player.vimeo.com/video/1169196245?h=5c5f7be273';

const photoRes = await fetchAPI('photos', { populate: 'image', 'pagination[limit]': '12' });
const cmsPhotos = (photoRes.data || []).map((p) => (p.image?.url ? mediaUrl(p.image.url) : null)).filter(Boolean);
const fallbackPhotos = Array.from({ length: 10 }, (_, i) => `/photos/photo${String(i + 1).padStart(2, '0')}.jpg`);
const photos = [...cmsPhotos, ...fallbackPhotos].slice(0, 8);

const daysRes = await fetchAPI('programme-days', { 'filters[edition][year][$eq]': '2025', sort: 'order:asc', populate: 'activities', 'pagination[limit]': '20' });
const days = daysRes.data || [];

const prizes = [
  { icon: '🏆', name: 'ZIFFA Grand Prize', winner: '2025 winner — TBC' },
  { icon: '🎬', name: 'Fiction Award', winner: '2025 winner — TBC' },
  { icon: '🎞️', name: 'Documentary Award', winner: '2025 winner — TBC' },
  { icon: '✨', name: 'Animation Award', winner: '2025 winner — TBC' },
];
const jury = [
  { ini: 'P', name: '2025 jury president', role: 'Presidency' },
  { ini: 'J2', name: 'Jury member', role: 'Directing' },
  { ini: 'J3', name: 'Jury member', role: 'Production' },
];
---
<Base title="2025 Edition — In pictures | ZIFFA" description="Relive the first ZIFFA edition (2025): video, gallery, prize list, programme and jury.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; 2025 Edition</div>
      <div class="eyebrow"><span class="arrow">→</span> Past edition · No.01</div>
      <h1>Looking back at <span class="yellow">2025</span>.</h1>
      <p>The first ZIFFA edition brought together audiences and professionals around African cinema.</p>
    </div>
  </header>

  <section class="video-2025-section" id="images">
    <div class="video-2025-inner">
      <div class="video-2025-head"><div class="eyebrow"><span class="arrow">→</span> The 2025 festival film</div><h2 class="section-title">The <span class="red">2025</span> edition<br />in <span class="italic">pictures</span>.</h2><p>The highlights of our first edition: screenings, masterclasses and encounters.</p></div>
      <div class="video-wrapper">
        <iframe src={VIDEO_2025} title="ZIFFA 2025 — festival film" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen loading="lazy" style="width:100%;height:100%;border:0;display:block;"></iframe>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> The gallery</div><h2 class="section-title"><span class="italic">2025</span> memories.</h2></div></div>
    <div class="gallery-grid">
      {photos.map((src, i) => (<figure class={i % 4 === 0 ? 'tall' : ''}><img src={src} alt="ZIFFA 2025" loading="lazy" /></figure>))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="prix">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> 2025 prize list</div><h2 class="section-title">The <span class="red">winners</span>.</h2></div></div>
    <div class="prize-grid">
      {prizes.map((p) => (<div class="prize-card"><div class="trophy">{p.icon}</div><h3>{p.name}</h3><div class="winner">{p.winner}</div></div>))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="programme-section" id="programme">
    <div class="programme-inner">
      <div style="text-align:center;margin-bottom:10px;"><div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> What happened</div><h2 class="section-title" style="margin:12px auto;text-align:center;">The 2025 <span class="italic">programme</span>.</h2></div>
      {days.length > 0 ? (
        <>
          <div class="prog-days-grid">
            {days.map((d, i) => (
              <a class="prog-day-card" href={`/en/programme/${d.slug}`}>
                <span class="pd-num">— Day {String(i + 1).padStart(2, '0')}</span>
                <span class="pd-label">{d.label}</span>
                {d.subtitle && <span class="pd-sub">{d.subtitle}</span>}
                <span class="pd-count">{(d.activities?.length || 0)} activities</span>
                <span class="pd-go">See details →</span>
              </a>
            ))}
          </div>
          <div class="prog-complete-btn">
            <a href="/en/programme-complet/2025" class="nav-cta">View the full programme ↗</a>
          </div>
        </>
      ) : (
        <p class="prog-pdf-empty" style="max-width:520px;margin:0 auto;">The 2025 programme will be available soon.</p>
      )}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="jury">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> The 2025 jury</div><h2 class="section-title">The <span class="italic">jury</span>.</h2></div></div>
    <div class="people-grid">
      {jury.map((j) => (<div class="person-card"><div class="person-avatar">{j.ini}</div><div class="person-name">{j.name}</div><div class="person-role">{j.role}</div></div>))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="masterclasses">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> 2025 knowledge sharing</div><h2 class="section-title">Master-<span class="italic">classes</span>.</h2></div></div>
    <div class="ateliers-grid">
      <div class="atelier-card"><span class="atelier-tag">— Masterclass</span><h3>Documentary <span class="italic">directing</span></h3><p>A first-edition workshop on writing reality.</p><div class="atelier-meta"><span>2025 Edition</span><span>Archive</span></div></div>
      <div class="atelier-card"><span class="atelier-tag">— Masterclass</span><h3>African <span class="italic">animation</span></h3><p>Discovering animation techniques with guest speakers.</p><div class="atelier-meta"><span>2025 Edition</span><span>Archive</span></div></div>
    </div>
  </section>

  <section class="objectifs-section" id="affiche">
    <div class="objectifs-inner">
      <div class="affiche-wrap">
        <div class="affiche-poster"><span class="placeholder">ZIFFA<br />2025</span></div>
        <div>
          <div class="eyebrow"><span class="arrow">→</span> 2025 visual identity</div>
          <h2 class="section-title" style="color:var(--bg);">The 2025 <span class="yellow-highlight">poster</span>.</h2>
          <p class="objectifs-tagline" style="margin:16px 0 28px;">The first edition's poster.</p>
          <a href="/en/edition-2027" class="nav-cta" style="background:var(--yellow);color:var(--green-deep);">See the 2027 edition ↗</a>
        </div>
      </div>
    </div>
  </section>
</Base>
