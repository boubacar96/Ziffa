{
  "kind": "collectionType",
  "collectionName": "programme_events",
  "info": {
    "singularName": "programme-event",
    "pluralName": "programme-events",
    "displayName": "Activité (programme)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "startTime": {
      "type": "string"
    },
    "timeEnd": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "ouverture",
        "cloture",
        "projection",
        "competition",
        "hors-competition",
        "masterclass",
        "rencontre",
        "ceremonie",
        "exposition",
        "vernissage",
        "cine-enfants",
        "festivites"
      ]
    },
    "location": {
      "type": "string"
    },
    "day": {
      "type": "integer"
    },
    "date": {
      "type": "date"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "films": {
      "type": "component",
      "repeatable": true,
      "component": "programme.film-line"
    },
    "speaker": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::person.person"
    },
    "programmeDay": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::programme-day.programme-day",
      "inversedBy": "activities"
    },
    "edition": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::edition.edition",
      "inversedBy": "events"
    }
  }
}
