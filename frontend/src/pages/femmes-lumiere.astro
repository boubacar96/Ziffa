---
import Base from '../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../lib/strapi.js';
import { fallbackFemmes } from '../lib/femmes-lumiere.js';

const res = await fetchAPI('femmes-lumiere', { populate: 'cover', sort: 'order:asc', 'pagination[limit]': '50' });
const cms = (res.data || []).map((f) => ({ slug: f.slug, title: f.title, excerpt: f.excerpt || '', cover: f.cover?.url ? mediaUrl(f.cover.url) : null }));
const femmes = cms.length ? cms.filter((f) => f.slug) : fallbackFemmes('fr');
---
<Base title="Femmes en lumière | ZIFFA" description="Femmes en lumière : portraits de réalisatrices, productrices et artistes qui font le cinéma africain au ZIFFA.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; <a href="/a-lannee">À l'année</a> &nbsp;/&nbsp; Femmes en lumière</div>
      <div class="eyebrow"><span class="arrow">→</span> Elles font le cinéma</div>
      <h1>Femmes en <span class="yellow">lumière</span>.</h1>
      <p>Portraits de réalisatrices, productrices et artistes qui font rayonner le cinéma africain.</p>
    </div>
  </header>

  <section class="section" id="panel">
    <div class="presentation-editorial" style="max-width:880px;">
      <p>Parmi les temps forts du ZIFFA, le panel <strong>« Femmes en Lumière »</strong> réunit des voix inspirantes pour échanger sur la place des femmes dans le cinéma : leurs défis, leurs ambitions et leur impact dans la création.</p>
      <p>Un espace d'écoute, de partage et de sororité, porté en partenariat avec la <strong>Plateforme des Femmes pour la Paix en Casamance</strong>.</p>
    </div>
  </section>

  <section class="section" id="portraits">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Elles font le cinéma</div><h2 class="section-title">Les <span class="italic">portraits</span>.</h2></div></div>
    <div class="formations-grid">
      {femmes.map((f) => (
        <a class="formation-card" href={`/femmes-lumiere/${f.slug}`}>
          <div class="formation-cover" style={f.cover ? `background-image:url('${f.cover}')` : ''}></div>
          <div class="formation-body">
            <h3>{f.title}</h3>
            {f.excerpt && <p>{f.excerpt}</p>}
            <span class="formation-more">Lire la suite →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
