---
import Base from '../layouts/Base.astro';
import UnderConstruction from '../components/UnderConstruction.astro';
---
<Base title="Contact & Infos | ZIFFA" description="Contactez l'équipe du ZIFFA.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; Infos</div>
      <div class="eyebrow"><span class="arrow">→</span> Nous contacter</div>
      <h1>On vous <span class="yellow">répond</span>.</h1>
      <p>Une question sur la programmation, la presse, les partenariats ou les inscriptions ? Écrivez-nous.</p>
    </div>
  </header>
  <UnderConstruction id="contact" eyebrow="Page Contact" />
</Base>
