---
import Base from '../../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../../lib/strapi.js';

const res = await fetchAPI('press-resources', { populate: 'files', sort: 'order:asc', 'pagination[limit]': '50' });
const fallback = [
  { title: 'Press kit', description: 'Full festival overview, key figures, programme strands and contacts.', category: 'PDF', files: [{ name: 'logo-ziffa.png', url: '/ziffa.png' }] },
  { title: 'Logos & brand guidelines', description: 'ZIFFA logos (colour, white) and brand usage rules.', category: 'Logos', files: [{ name: 'logo-ziffa.png', url: '/ziffa.png' }] },
  { title: 'Official photo library', description: 'A selection of royalty-free HD photos for the press.', category: 'Photos', files: [{ name: 'logo-ziffa.png', url: '/ziffa.png' }] },
];
const cms = (res.data || []).map((r) => ({
  title: r.title, description: r.description || '', category: r.category || '',
  files: (r.files || []).map((f) => ({ name: f.name, url: mediaUrl(f.url) })),
}));
const resources = cms.length ? cms : fallback;
---
<Base title="Press area | ZIFFA" description="ZIFFA press area: press kit, logos & brand guidelines, official photo library — to download.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; <a href="/en/le-ziffa#presse">The ZIFFA</a> &nbsp;/&nbsp; Press</div>
      <div class="eyebrow"><span class="arrow">→</span> Press area</div>
      <h1>Press <span class="yellow">area</span>.</h1>
      <p>Download ZIFFA's official resources: one by one, by selection or all at once.</p>
    </div>
  </header>

  <section class="section">
    <div class="press-toolbar">
      <label class="press-selectall"><input type="checkbox" id="press-all-cb" /> Select all</label>
      <div class="press-toolbar-actions">
        <button type="button" class="btn-ghost" id="press-dl-selection" style="color:var(--green-deep);border-color:var(--line);">Download selection</button>
        <button type="button" class="nav-cta" id="press-dl-all">Download all ↓</button>
      </div>
    </div>

    <div class="press-grid" id="press-grid">
      {resources.map((r, idx) => (
        <article class="press-card" data-idx={idx}>
          <label class="press-check"><input type="checkbox" class="press-cb" /></label>
          {r.category && <span class="press-cat">{r.category}</span>}
          <h3>{r.title}</h3>
          {r.description && <p>{r.description}</p>}
          <div class="press-files">
            {r.files.length === 0 && <span class="press-empty">File coming soon</span>}
            {r.files.map((f) => (
              <a class="press-file" href={f.url} download data-url={f.url} data-name={f.name}><span>📄 {f.name}</span><span class="press-file-dl">↓</span></a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>

<script>
  const grid = document.getElementById('press-grid');
  if (grid) {
    const cards = Array.from(grid.querySelectorAll('.press-card'));
    const filesOf = (card) => Array.from(card.querySelectorAll('.press-file')).map((a) => ({ url: a.dataset.url, name: a.dataset.name }));
    function downloadAll(files) {
      files.forEach((f, i) => setTimeout(() => {
        const a = document.createElement('a');
        a.href = f.url; a.download = f.name || ''; a.target = '_blank'; a.rel = 'noopener';
        document.body.appendChild(a); a.click(); a.remove();
      }, i * 400));
    }
    document.getElementById('press-all-cb')?.addEventListener('change', (e) => {
      cards.forEach((c) => { const cb = c.querySelector('.press-cb'); cb.checked = e.target.checked; c.classList.toggle('selected', e.target.checked); });
    });
    cards.forEach((c) => c.querySelector('.press-cb').addEventListener('change', (e) => c.classList.toggle('selected', e.target.checked)));
    document.getElementById('press-dl-selection')?.addEventListener('click', () => {
      const sel = cards.filter((c) => c.querySelector('.press-cb').checked);
      const files = sel.flatMap(filesOf);
      if (!files.length) { alert('Select at least one resource.'); return; }
      downloadAll(files);
    });
    document.getElementById('press-dl-all')?.addEventListener('click', () => downloadAll(cards.flatMap(filesOf)));
  }
</script>
