---
import Base from '../../layouts/Base.astro';
import { PRESS_PARTS } from '../../lib/press.js';
---
<Base title="Press area | ZIFFA" description="ZIFFA press area: press kit, logos & brand guidelines, official photo library.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; <a href="/en/le-ziffa#presse">The ZIFFA</a> &nbsp;/&nbsp; Press</div>
      <div class="eyebrow"><span class="arrow">→</span> Press area</div>
      <h1>Press <span class="yellow">area</span>.</h1>
      <p>Choose a section to access its official resources, ready to download.</p>
    </div>
  </header>

  <section class="section">
    <div class="presse-cards">
      {PRESS_PARTS.map((p) => (
        <a class={`presse-card pc-${p.color}`} href={`/en/presse/${p.key}`}>
          <span class="presse-ic">{p.icon}</span>
          <h3>{p.en.title}</h3>
          <p>{p.en.desc}</p>
          <span class="presse-go">Open →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
