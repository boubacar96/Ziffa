---
import Base from '../../layouts/Base.astro';
import { fetchAPI, mediaUrl, mediaUrls, getVimeoThumb } from '../../lib/strapi.js';
import { fallbackMasterclasses } from '../../lib/masterclasses.js';
import { FILMS_2025 } from '../../lib/films2025.js';
import FilmWall from '../../components/FilmWall.astro';

const VIDEO_2025 = 'https://player.vimeo.com/video/1169196245?h=5c5f7be273';
const teaserThumb = await getVimeoThumb(VIDEO_2025);

const photoRes = await fetchAPI('photos', { populate: 'image', 'pagination[limit]': '12' });
const cmsPhotos = (photoRes.data || []).flatMap((p) => mediaUrls(p.image));
const fallbackPhotos = Array.from({ length: 10 }, (_, i) => `/photos/photo${String(i + 1).padStart(2, '0')}.jpg`);
const photos = [...cmsPhotos, ...fallbackPhotos].slice(0, 8);

const daysRes = await fetchAPI('programme-days', { 'filters[edition][year][$eq]': '2025', sort: 'order:asc', populate: 'activities', 'pagination[limit]': '20' });
const days = daysRes.data || [];

const prizeRes = await fetchAPI('prizes', { 'filters[edition][year][$eq]': '2025', populate: 'image', 'pagination[limit]': '20' });
const cmsPrizes = (prizeRes.data || []).map((p) => ({ name: p.name, winner: p.winner || '', image: p.image?.url ? mediaUrl(p.image.url) : null }));
const fallbackPrizes = [
  { name: 'Best fiction feature from the sub-region', winner: '', image: null },
  { name: 'Best international fiction feature', winner: '', image: null },
  { name: 'New Generation Award — West Africa', winner: '', image: null },
  { name: 'New Generation Award — International', winner: '', image: null },
  { name: 'Audience Award', winner: '', image: null },
];
const prizes = cmsPrizes.length ? cmsPrizes : fallbackPrizes;

const juryRes = await fetchAPI('people', { 'filters[type][$eq]': 'jury', 'filters[edition][year][$eq]': '2025', sort: 'order:asc', populate: 'photo' });
const cmsJury = (juryRes.data || []).map((j) => ({ ini: (j.name || '?').slice(0, 2).toUpperCase(), name: j.name, role: j.role || '', bio: j.bio || '', photo: j.photo?.url ? mediaUrl(j.photo.url) : null }));
const fallbackJury = [
  { ini: 'P', name: '2025 jury president', role: 'Presidency', bio: 'To be announced.', photo: null },
  { ini: 'J2', name: 'Jury member', role: 'Directing', bio: 'To be announced.', photo: null },
  { ini: 'J3', name: 'Jury member', role: 'Production', bio: 'To be announced.', photo: null },
];
const jury = cmsJury.length ? cmsJury : fallbackJury;

const mcRes = await fetchAPI('masterclasses', { 'filters[edition][year][$eq]': '2025', populate: 'cover', sort: 'order:asc', 'pagination[limit]': '20' });
const cmsMc = (mcRes.data || []).map((m) => ({ slug: m.slug, title: m.title, excerpt: m.excerpt || '', cover: m.cover?.url ? mediaUrl(m.cover.url) : null }));
const masterclasses = cmsMc.length ? cmsMc.filter((m) => m.slug) : fallbackMasterclasses('en');

const filmRes = await fetchAPI('films', { 'filters[edition][year][$eq]': '2025', populate: 'poster', sort: 'title:asc', 'pagination[limit]': '100' });
const cmsFilms = (filmRes.data || []).map((f) => ({ title: f.title, director: f.director || '', country: f.country || '', year: f.year || '', duration: f.duration || '', poster: f.poster?.url ? mediaUrl(f.poster.url) : null, synopsis: f.synopsis || '', trailerUrl: f.trailerUrl || '' }));
const films2025 = cmsFilms.length ? cmsFilms : FILMS_2025;

const edStats = [
  { n: 42, suffix: '', label: 'films screened' },
  { n: 3350, suffix: '', label: 'festival-goers' },
  { n: 419, suffix: '', label: 'talents trained' },
  { n: 7, suffix: '', label: 'awards given' },
];
const highlights = [
  { img: photos[0] || '/photos/photo01.jpg', title: 'Ceremonies & organisation', desc: 'Opening, closing and behind the scenes of the festival.' },
  { img: photos[3] || '/photos/photo04.jpg', title: 'Workshops', desc: 'Twelve days of training: directing, editing, acting and animation.' },
  { img: photos[5] || '/photos/photo06.jpg', title: 'Animation & kids screenings', desc: 'Animated film sessions and workshops for young audiences.' },
  { img: photos[2] || '/photos/photo03.jpg', title: 'Masterclasses', desc: 'Knowledge-sharing with guest filmmakers and professionals.' },
  { img: photos[6] || '/photos/photo07.jpg', title: 'Women in the spotlight', desc: 'Talks with directors, producers and creators.' },
];
---
<Base title="2025 Edition — In pictures | ZIFFA" description="Relive the first ZIFFA edition (2025): video, gallery, prize list, programme and jury.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; 2025 Edition</div>
      <div class="eyebrow"><span class="arrow">→</span> Past edition · No.01</div>
      <h1>Looking back at <span class="yellow">2025</span>.</h1>
      <p>The first ZIFFA edition brought together audiences and professionals around African cinema.</p>
    </div>
  </header>

  <section class="section" id="chiffres">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> The edition in figures</div><h2 class="section-title">2025 in <span class="red">numbers</span>.</h2></div></div>
    <div class="edstat-band">
      {edStats.map((s) => (
        <div class="edstat">
          <div class="edstat-num" data-count={String(s.n)}><span class="edstat-val">{s.n}</span>{s.suffix && <span class="edstat-suffix">{s.suffix}</span>}</div>
          <div class="edstat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="teaser-section" id="images">
    <div class="teaser-inner">
      <div class="teaser-head">
        <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> The 2025 festival film</div>
        <h2 class="section-title">The <span class="red">2025</span> edition in <span class="italic">pictures</span>.</h2>
        <p>The highlights of our first edition: screenings, masterclasses and encounters.</p>
      </div>
      <div class="teaser-player" id="teaser-player" data-embed={VIDEO_2025} role="button" tabindex="0" aria-label="Play the 2025 edition film">
        <div class="teaser-poster" style={`background-image:linear-gradient(rgba(11,26,18,.28),rgba(11,26,18,.55)), url('/teaser-cover.jpg')${teaserThumb ? `, url('${teaserThumb}')` : ''}`}></div>
        <div class="teaser-play"><span>▶</span></div>
        <div class="teaser-cta">Watch the festival film</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> The gallery</div><h2 class="section-title"><span class="italic">2025</span> memories.</h2></div><a href="/en/galerie/2025" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">View the full gallery →</a></div>
    <div class="gallery-marquee">
      <div class="gallery-marquee-track">
        {photos.map((src) => (<figure><img src={src} alt="ZIFFA 2025" loading="lazy" /></figure>))}
        {photos.map((src) => (<figure aria-hidden="true"><img src={src} alt="" loading="lazy" /></figure>))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="temps-forts">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Highlights</div><h2 class="section-title">The <span class="red">highlights</span>.</h2></div></div>
    <div class="hl-cards">
      {highlights.map((h) => (
        <article class="hl-card">
          <div class="hl-card-img" style={`background-image:url('${h.img}')`}></div>
          <div class="hl-card-body"><h3>{h.title}</h3><p>{h.desc}</p></div>
        </article>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="selection">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Official selection</div><h2 class="section-title">The 2025 <span class="red">films</span>.</h2></div><a href="/en/films/2025" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);align-self:flex-start;">See all ({films2025.length}) →</a></div>
    <FilmWall films={films2025} lang="en" layout="row" />
  </section>

  <hr class="section-divider" />

  <section class="section" id="prix">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Prize list</div><h2 class="section-title">Awards &amp; <span class="red">distinctions</span>.</h2></div></div>
    <p class="lead" style="max-width:760px;margin-bottom:30px;">An international jury awarded 7 prizes and 2 special mentions:</p>
    <div class="prize-grid">
      {prizes.map((p, i) => (p.image ? (
        <div class="prize-photo" data-zoom={p.image} data-caption={`${p.name}${p.winner ? ' — ' + p.winner : ''}`} style={`background-image:linear-gradient(to top, rgba(15,58,32,.94) 0%, rgba(15,58,32,.15) 55%, rgba(15,58,32,0) 100%), url('${p.image}')`}>
          <div class="prize-photo-body"><h3>{p.name}</h3>{p.winner && <div class="winner">{p.winner}</div>}</div>
        </div>
      ) : (
        <div class={`prize-card prize-card--accent oc-${['red', 'green', 'yellow', 'orange'][i % 4]}`}><h3>{p.name}</h3><div class="winner">{p.winner || 'Winner to be announced'}</div></div>
      )))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="programme-section" id="programme">
    <div class="programme-inner">
      <div style="text-align:center;margin-bottom:10px;"><div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> What happened</div><h2 class="section-title" style="margin:12px auto;text-align:center;">The 2025 <span class="italic">programme</span>.</h2></div>
      {days.length > 0 ? (
        <>
          <div class="prog-days-grid">
            {days.map((d, i) => (
              <a class="prog-day-card" href={`/en/programme/${d.slug}`}>
                <span class="pd-num">— Day {String(i + 1).padStart(2, '0')}</span>
                <span class="pd-label">{d.label}</span>
                {d.subtitle && <span class="pd-sub">{d.subtitle}</span>}
                <span class="pd-count">{(d.activities?.length || 0)} activities</span>
                <span class="pd-go">See details →</span>
              </a>
            ))}
          </div>
          <div class="prog-complete-btn">
            <a href="/en/programme-complet/2025" class="nav-cta">View the full programme ↗</a>
          </div>
        </>
      ) : (
        <p class="prog-pdf-empty" style="max-width:520px;margin:0 auto;">The 2025 programme will be available soon.</p>
      )}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="jury">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> The 2025 jury</div><h2 class="section-title">The <span class="italic">jury</span>.</h2></div></div>
    <div class="team-grid">
      {jury.map((j) => (
        <button type="button" class="team-portrait js-person" data-name={j.name} data-role={j.role} data-bio={j.bio} data-photo={j.photo || ''} data-ini={j.ini}>
          <div class="team-photo" style={j.photo ? `background-image:url('${j.photo}')` : ''}>{j.photo ? '' : <span class="team-ini">{j.ini}</span>}</div>
          <div class="team-info"><div class="team-name">{j.name}</div><div class="team-role">{j.role}</div></div>
        </button>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="masterclasses">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> 2025 knowledge sharing</div><h2 class="section-title">Master-<span class="italic">classes</span>.</h2></div></div>
    <div class="formations-grid">
      {masterclasses.map((m) => (
        <a class="formation-card" href={`/en/masterclasses/${m.slug}`}>
          <div class="formation-cover" style={m.cover ? `background-image:url('${m.cover}')` : ''}></div>
          <div class="formation-body"><h3>{m.title}</h3>{m.excerpt && <p>{m.excerpt}</p>}<span class="formation-more">Read more →</span></div>
        </a>
      ))}
    </div>
  </section>

  <div class="person-modal" id="person-modal" hidden>
    <div class="pm-backdrop" data-close></div>
    <div class="pm-dialog" role="dialog" aria-modal="true" aria-labelledby="pm-name">
      <button class="pm-close" data-close aria-label="Close">×</button>
      <div class="pm-photo" id="pm-photo"></div>
      <div class="pm-body">
        <div class="pm-role" id="pm-role"></div>
        <h3 id="pm-name"></h3>
        <p id="pm-bio"></p>
      </div>
    </div>
  </div>
</Base>

<script>
  const tp = document.getElementById('teaser-player');
  if (tp) {
    const play = () => {
      if (tp.classList.contains('playing')) return;
      const base = tp.dataset.embed;
      const src = base + (base.includes('?') ? '&' : '?') + 'autoplay=1';
      tp.innerHTML = '<iframe src="' + src + '" title="ZIFFA 2025 — festival film" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="width:100%;height:100%;border:0;display:block;"></iframe>';
      tp.classList.add('playing');
    };
    tp.addEventListener('click', play);
    tp.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); play(); } });
  }

  const band = document.querySelector('.edstat-band');
  if (band) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const run = () => {
      band.querySelectorAll('.edstat-num').forEach((el) => {
        const val = el.querySelector('.edstat-val');
        const target = parseInt(el.dataset.count, 10) || 0;
        if (reduce) { val.textContent = String(target); return; }
        const dur = 1200; const t0 = performance.now();
        val.textContent = '0';
        const step = (now) => {
          const p = Math.min(1, (now - t0) / dur);
          val.textContent = String(Math.round((1 - Math.pow(1 - p, 3)) * target));
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      });
    };
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((es) => { es.forEach((e) => { if (e.isIntersecting) { run(); io.disconnect(); } }); }, { threshold: 0.4 });
      io.observe(band);
    } else { run(); }
  }

  const modal = document.getElementById('person-modal');
  if (modal) {
    const pmPhoto = document.getElementById('pm-photo');
    const pmName = document.getElementById('pm-name');
    const pmRole = document.getElementById('pm-role');
    const pmBio = document.getElementById('pm-bio');
    const pmClose = modal.querySelector('.pm-close');
    let pmLast = null;
    const open = (d) => {
      pmName.textContent = d.name || '';
      pmRole.textContent = d.role || '';
      pmBio.textContent = d.bio || '';
      if (d.photo) { pmPhoto.style.backgroundImage = `url('${d.photo}')`; pmPhoto.textContent = ''; pmPhoto.classList.remove('pm-photo--ini'); }
      else { pmPhoto.style.backgroundImage = ''; pmPhoto.textContent = d.ini || ''; pmPhoto.classList.add('pm-photo--ini'); }
      modal.hidden = false; document.body.style.overflow = 'hidden';
      pmLast = document.activeElement; pmClose.focus();
    };
    const close = () => { modal.hidden = true; document.body.style.overflow = ''; if (pmLast && pmLast.focus) pmLast.focus(); };
    document.querySelectorAll('.js-person').forEach((c) => c.addEventListener('click', () => open(c.dataset)));
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (modal.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'Tab') { e.preventDefault(); pmClose.focus(); }
    });
  }
</script>
