---
import { getLangFromUrl, useTranslations, lp, altPath } from '../i18n.js';
import { resolveNav } from '../lib/nav.js';
const NAV = await resolveNav();
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = (Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/');
const L = (p) => lp(p, lang);
const frHref = altPath(Astro.url, 'fr');
const enHref = altPath(Astro.url, 'en');
const pagePath = (href) => (href || '').split('#')[0];
const groupActive = (g) => {
  const paths = [g.href, ...g.items.map((i) => pagePath(i.href))].filter(Boolean);
  return paths.some((p) => base === p || base.startsWith(p + '/')) ? 'active' : '';
};
---
<div class="top-strip">
  <div><span class="dot"></span>{t('topstrip.edition')}</div>
  <div class="top-strip-right">
    <a href={L('/contact') + '#contact'}>{t('nav.presse')}</a>
    <a href={L('/contact') + '#contact'}>{t('footer.contact')}</a>
  </div>
</div>

<nav class="navbar">
  <a href={L('/')} class="logo" aria-label="ZIFFA">
    <img src="/ziffa.png" alt="ZIFFA - Ziguinchor International Festival Film and Animation" width="220" height="80" decoding="async" fetchpriority="high" />
  </a>

  <button class="nav-toggle" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>

  <ul class="nav-links">
    {NAV.map((g) => {
      const hasItems = g.items && g.items.length > 0;
      return (
        <li class="nav-item">
          {g.href
            ? <a class={`nav-link ${groupActive(g)}`} href={L(g.href)}>{t(g.key)}{hasItems && <span class="caret"> ▾</span>}</a>
            : <span class={`nav-link nav-link--toggle ${groupActive(g)}`} role="button" tabindex="0">{t(g.key)}{hasItems && <span class="caret"> ▾</span>}</span>}
          {hasItems && (
            <div class="dropdown">
              {g.items.map((i) => (
                i.items && i.items.length ? (
                  <div class="dd-sub">
                    <a href={L(i.href)} class="dd-sub-link">{i.label ? i.label[lang] : t(i.key)}<span class="dd-arrow">›</span></a>
                    <div class="dropdown-flyout">
                      {i.items.map((s) => <a href={L(s.href)}>{s.label ? s.label[lang] : t(s.key)}</a>)}
                    </div>
                  </div>
                ) : (
                  <a href={L(i.href)}>{i.label ? i.label[lang] : t(i.key)}</a>
                )
              ))}
            </div>
          )}
        </li>
      );
    })}
  </ul>

  <div class="nav-right">
    <div class="lang-pill">
      <a href={frHref} class={lang === 'fr' ? 'active' : ''}>FR</a>
      <a href={enHref} class={lang === 'en' ? 'active' : ''}>EN</a>
    </div>
    <a href={L('/accreditation')} class="nav-cta">{t('nav.accrediter')} ↗</a>
  </div>
</nav>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const links = document.querySelector('.nav-links');
  if (toggle && links) {
    toggle.addEventListener('click', () => {
      const open = links.classList.toggle('open');
      toggle.classList.toggle('open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
    document.querySelectorAll('.nav-item > .nav-link').forEach((link) => {
      link.addEventListener('click', (e) => {
        if (window.matchMedia('(max-width: 1200px)').matches) {
          const item = link.parentElement;
          if (!item.classList.contains('open')) {
            e.preventDefault();
            document.querySelectorAll('.nav-item.open').forEach((o) => { if (o !== item) o.classList.remove('open'); });
            item.classList.add('open');
          }
        }
      });
    });
  }
</script>
