---
import Base from '../../layouts/Base.astro';
import { COUNTRIES } from '../../lib/countries.js';

const countries = COUNTRIES.map((c) => c.en);
const mediaOptions = ['News Agency', 'Written Press', 'Online Press', 'Radio', 'TV', 'News Correspondent', 'Freelance'];
const professionOptions = ['Director', 'Producer', 'Distributor', 'Screenwriter', 'Actor / Actress', 'Director of Photography', 'Editor', 'Sound Engineer', 'Composer', 'Production Designer', 'Costume Designer', 'Film Critic', 'Programmer', 'Sales Agent', 'Other'];
---
<Base title="Get accredited | ZIFFA" description="Apply for ZIFFA accreditation: press, festival representative or film trades.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; Get accredited</div>
      <div class="eyebrow"><span class="arrow">→</span> Accreditation · 2027 Edition</div>
      <h1>Get <span class="yellow">accredited</span>.</h1>
      <p>Press, festival representatives and film professionals: apply for your ZIFFA accreditation.</p>
    </div>
  </header>

  <section class="section" id="accreditation">
    <div class="insc-main" style="max-width:900px;margin:0 auto;">
      <div id="acc-alert" class="form-alert"></div>

      <form id="acc-form" class="insc-form" enctype="multipart/form-data" novalidate>
        <div class="hp"><label>Do not fill<input type="text" name="website" tabindex="-1" autocomplete="off" /></label></div>

        <div class="insc-step" style="--accent: var(--red);">
          <div class="insc-step-head"><span class="insc-step-num">1</span><h3>Your option<small>Accreditation type</small></h3></div>
          <div class="acc-options">
            <label class="acc-opt"><input type="radio" name="option" value="press" required /> <span>I — Press</span></label>
            <label class="acc-opt"><input type="radio" name="option" value="festival" /> <span>II — Festival representative</span></label>
            <label class="acc-opt"><input type="radio" name="option" value="trades" /> <span>III — Film trades</span></label>
          </div>
        </div>

        <!-- ===================== BRANCH I — PRESS ===================== -->
        <div class="acc-branch" data-branch="press" hidden>
          <div class="insc-step" style="--accent: var(--green);">
            <div class="insc-step-head"><span class="insc-step-num">2</span><h3>Identity<small>The accredited person</small></h3></div>
            <div class="grid2">
              <div class="field"><label>First name <span class="req">*</span></label><input type="text" name="p_firstName" required /></div>
              <div class="field"><label>Last name <span class="req">*</span></label><input type="text" name="p_lastName" required /></div>
            </div>
            <div class="field"><label>Occupation <span class="req">*</span></label><input type="text" name="p_function" required /></div>
          </div>

          <div class="insc-step" style="--accent: var(--yellow);">
            <div class="insc-step-head"><span class="insc-step-num">3</span><h3>Personal information</h3></div>
            <div class="field"><label>Profession</label><input type="text" name="p_profession" /></div>
            <div class="grid2">
              <div class="field"><label>Address</label><input type="text" name="p_address" /></div>
              <div class="field"><label>WhatsApp number</label><input type="text" name="p_whatsapp" /></div>
              <div class="field"><label>Email <span class="req">*</span></label><input type="email" name="p_email" required /></div>
              <div class="field"><label>Town</label><input type="text" name="p_city" /></div>
            </div>
            <div class="field"><label>Country <span class="req">*</span></label>
              <select name="p_country" required><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select>
            </div>
          </div>

          <div class="insc-step" style="--accent: var(--orange);">
            <div class="insc-step-head"><span class="insc-step-num">4</span><h3>Media & company</h3></div>
            <div class="field"><label>Media <span class="req">*</span></label>
              <select name="p_media" required><option value="">— Choose —</option>{mediaOptions.map((m) => <option>{m}</option>)}</select>
            </div>
            <div class="grid2">
              <div class="field"><label>Company name <span class="req">*</span></label><input type="text" name="p_orgName" required /></div>
              <div class="field"><label>Company address</label><input type="text" name="p_orgAddress" /></div>
              <div class="field"><label>WhatsApp number</label><input type="text" name="p_orgWhatsapp" /></div>
              <div class="field"><label>Company email <span class="req">*</span></label><input type="email" name="p_orgEmail" required /></div>
              <div class="field"><label>Town</label><input type="text" name="p_orgCity" /></div>
              <div class="field"><label>Country</label><select name="p_orgCountry"><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
            </div>
          </div>

          <div class="insc-step" style="--accent: var(--red);">
            <div class="insc-step-head"><span class="insc-step-num">5</span><h3>Documents</h3></div>
            <div class="field"><label>Professional card <span class="req">*</span></label>
              <div class="file-drop"><input type="file" name="p_card" required /><div class="fd-icon">💳</div><div class="fd-text"><b>Click</b> or drop your press card</div><div class="fd-files"></div></div>
            </div>
            <div class="field"><label>Identity photo <span class="req">*</span></label>
              <div class="file-drop"><input type="file" name="p_idPhoto" accept="image/*" required /><div class="fd-icon">📷</div><div class="fd-text"><b>Click</b> or drop your photo</div><div class="fd-files"></div></div>
            </div>
          </div>
        </div>

        <!-- ============== BRANCH II — FESTIVAL REPRESENTATIVE ============== -->
        <div class="acc-branch" data-branch="festival" hidden>
          <div class="insc-step" style="--accent: var(--green);">
            <div class="insc-step-head"><span class="insc-step-num">2</span><h3>The representative</h3></div>
            <div class="field"><label>Occupation <span class="req">*</span></label><input type="text" name="f_function" required /></div>
            <div class="grid2">
              <div class="field"><label>First name <span class="req">*</span></label><input type="text" name="f_firstName" required /></div>
              <div class="field"><label>Last name <span class="req">*</span></label><input type="text" name="f_lastName" required /></div>
            </div>
            <div class="field"><label>Profession</label><input type="text" name="f_profession" /></div>
            <div class="grid2">
              <div class="field"><label>Address</label><input type="text" name="f_address" /></div>
              <div class="field"><label>WhatsApp number</label><input type="text" name="f_whatsapp" /></div>
              <div class="field"><label>Email <span class="req">*</span></label><input type="email" name="f_email" required /></div>
              <div class="field"><label>Town</label><input type="text" name="f_city" /></div>
            </div>
            <div class="field"><label>Country</label><select name="f_country"><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
          </div>

          <div class="insc-step" style="--accent: var(--yellow);">
            <div class="insc-step-head"><span class="insc-step-num">3</span><h3>The festival</h3></div>
            <div class="field"><label>Festival name <span class="req">*</span></label><input type="text" name="f_festName" required /></div>
            <div class="grid2">
              <div class="field"><label>Festival address</label><input type="text" name="f_festAddress" /></div>
              <div class="field"><label>WhatsApp number</label><input type="text" name="f_festWhatsapp" /></div>
              <div class="field"><label>Email</label><input type="email" name="f_festEmail" /></div>
              <div class="field"><label>Town</label><input type="text" name="f_festCity" /></div>
            </div>
            <div class="field"><label>Country</label><select name="f_festCountry"><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
          </div>

          <div class="insc-step" style="--accent: var(--orange);">
            <div class="insc-step-head"><span class="insc-step-num">4</span><h3>Festival director & document</h3></div>
            <div class="grid2">
              <div class="field"><label>Director first name <span class="req">*</span></label><input type="text" name="f_dirFirstName" required /></div>
              <div class="field"><label>Director last name <span class="req">*</span></label><input type="text" name="f_dirLastName" required /></div>
            </div>
            <div class="field"><label>Director's email</label><input type="email" name="f_dirEmail" /></div>
            <div class="field"><label>Identity photo <span class="req">*</span></label>
              <div class="file-drop"><input type="file" name="f_idPhoto" accept="image/*" required /><div class="fd-icon">📷</div><div class="fd-text"><b>Click</b> or drop your photo</div><div class="fd-files"></div></div>
            </div>
          </div>
        </div>

        <!-- ============== BRANCH III — FILM TRADES ============== -->
        <div class="acc-branch" data-branch="trades" hidden>
          <div class="insc-step" style="--accent: var(--green);">
            <div class="insc-step-head"><span class="insc-step-num">2</span><h3>Identity & profession</h3></div>
            <div class="field"><label>Occupation <span class="req">*</span></label><input type="text" name="t_function" required /></div>
            <div class="grid2">
              <div class="field"><label>First name <span class="req">*</span></label><input type="text" name="t_firstName" required /></div>
              <div class="field"><label>Last name <span class="req">*</span></label><input type="text" name="t_lastName" required /></div>
              <div class="field"><label>Country of origin <span class="req">*</span></label><select name="t_countryOrigin" required><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
              <div class="field"><label>Other nationality <span class="req">*</span></label><select name="t_otherNationality" required><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
            </div>
            <div class="field"><label>Profession <span class="req">*</span></label>
              <select name="t_profession" required><option value="">— Choose —</option>{professionOptions.map((p) => <option>{p}</option>)}</select>
            </div>
          </div>

          <div class="insc-step" style="--accent: var(--yellow);">
            <div class="insc-step-head"><span class="insc-step-num">3</span><h3>Personal address</h3></div>
            <div class="grid2">
              <div class="field"><label>Address</label><input type="text" name="t_address" /></div>
              <div class="field"><label>WhatsApp number</label><input type="text" name="t_whatsapp" /></div>
              <div class="field"><label>Email <span class="req">*</span></label><input type="email" name="t_email" required /></div>
              <div class="field"><label>Town</label><input type="text" name="t_city" /></div>
            </div>
            <div class="field"><label>Country</label><select name="t_country"><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
          </div>

          <div class="insc-step" style="--accent: var(--orange);">
            <div class="insc-step-head"><span class="insc-step-num">4</span><h3>Production company</h3></div>
            <div class="field"><label>Company name <span class="req">*</span></label><input type="text" name="t_prodName" required /></div>
            <div class="grid2">
              <div class="field"><label>Address</label><input type="text" name="t_prodAddress" /></div>
              <div class="field"><label>WhatsApp number</label><input type="text" name="t_prodWhatsapp" /></div>
              <div class="field"><label>Email</label><input type="email" name="t_prodEmail" /></div>
              <div class="field"><label>Town</label><input type="text" name="t_prodCity" /></div>
            </div>
            <div class="field"><label>Country</label><select name="t_prodCountry"><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
          </div>

          <div class="insc-step" style="--accent: var(--red);">
            <div class="insc-step-head"><span class="insc-step-num">5</span><h3>Distribution company</h3></div>
            <div class="field"><label>Company name <span class="req">*</span></label><input type="text" name="t_distName" required /></div>
            <div class="grid2">
              <div class="field"><label>Address</label><input type="text" name="t_distAddress" /></div>
              <div class="field"><label>WhatsApp number</label><input type="text" name="t_distWhatsapp" /></div>
              <div class="field"><label>Email</label><input type="email" name="t_distEmail" /></div>
              <div class="field"><label>Town</label><input type="text" name="t_distCity" /></div>
            </div>
            <div class="field"><label>Country</label><select name="t_distCountry"><option value="">— Country —</option>{countries.map((c) => <option>{c}</option>)}</select></div>
          </div>

          <div class="insc-step" style="--accent: var(--green);">
            <div class="insc-step-head"><span class="insc-step-num">6</span><h3>Documents</h3></div>
            <div class="field"><label>Identity photo <span class="req">*</span></label>
              <div class="file-drop"><input type="file" name="t_idPhoto" accept="image/*" required /><div class="fd-icon">📷</div><div class="fd-text"><b>Click</b> or drop your photo</div><div class="fd-files"></div></div>
            </div>
            <div class="field"><label>Bio-filmography (PDF or Word, no CV) <span class="req">*</span></label>
              <div class="file-drop"><input type="file" name="t_biofilmo" accept=".pdf,.doc,.docx" required /><div class="fd-icon">📄</div><div class="fd-text"><b>Click</b> or drop the file · max 10 MB</div><div class="fd-files"></div></div>
            </div>
          </div>
        </div>

        <button type="submit" class="submit-btn" id="acc-submit" hidden>Send my request ↗</button>
      </form>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById('acc-form');
  const alertBox = document.getElementById('acc-alert');
  const submitBtn = document.getElementById('acc-submit');
  const branches = form ? Array.from(form.querySelectorAll('.acc-branch')) : [];

  function setBranch(val) {
    branches.forEach((b) => {
      const on = b.dataset.branch === val;
      b.hidden = !on;
      b.querySelectorAll('input, select, textarea').forEach((el) => { el.disabled = !on; });
    });
    if (submitBtn) submitBtn.hidden = !val;
  }
  setBranch(null);
  form?.querySelectorAll('input[name="option"]').forEach((r) => r.addEventListener('change', () => setBranch(r.value)));

  form?.querySelectorAll('.file-drop input[type="file"]').forEach((input) => {
    const drop = input.closest('.file-drop');
    const list = drop.querySelector('.fd-files');
    input.addEventListener('change', () => {
      const names = Array.from(input.files).map((f) => f.name);
      list.textContent = names.join(' · ');
      drop.classList.toggle('has-files', names.length > 0);
    });
  });

  const showAlert = (type, msg) => { alertBox.className = 'form-alert show ' + type; alertBox.textContent = msg; alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' }); };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form.querySelector('input[name="option"]:checked')) { showAlert('err', 'Please choose an accreditation option.'); return; }
    if (!form.checkValidity()) { showAlert('err', 'Please fill in all required fields (*).'); return; }
    submitBtn.disabled = true; const original = submitBtn.textContent; submitBtn.textContent = 'Sending…';
    try {
      const res = await fetch('/api/accreditation-submission', { method: 'POST', body: new FormData(form) });
      const data = await res.json();
      if (data.ok) {
        showAlert('ok', '✅ Thank you! Your accreditation request has been sent. You will receive a reply by email.');
        form.reset(); setBranch(null);
        form.querySelectorAll('.file-drop').forEach((d) => { d.classList.remove('has-files'); d.querySelector('.fd-files').textContent = ''; });
      } else { showAlert('err', '⚠️ ' + (data.error || 'An error occurred.')); }
    } catch (err) { showAlert('err', '⚠️ Submission failed. Check your connection and try again.'); }
    finally { submitBtn.disabled = false; submitBtn.textContent = original; }
  });
</script>
