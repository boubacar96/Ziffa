---
import Base from '../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../lib/strapi.js';

// Équipe (Strapi `person` type=equipe) avec repli.
const teamRes = await fetchAPI('people', { 'filters[type][$eq]': 'equipe', sort: 'order:asc', populate: 'photo' });
const cmsTeam = teamRes.data || [];
const mapPerson = (p) => ({ ini: (p.name || '?').slice(0, 2).toUpperCase(), name: p.name, role: p.role || '', bio: p.bio || '', photo: p.photo?.url ? mediaUrl(p.photo.url) : null, featured: !!p.featured });
const fallbackTeam = [
  { ini: 'BB', name: 'Babacar Ba', role: 'Président du festival', bio: "Producteur audiovisuel, réalisateur et photographe, diplômé de l’École Agnès Varda (Bruxelles). Fondateur du ZIFFA, il œuvre depuis une vingtaine d’années à faire émerger les talents du cinéma sénégalais et à faire de Ziguinchor un carrefour du cinéma africain.", photo: null, featured: true },
  { ini: 'YP', name: 'Yves-François Preira', role: 'Président de FOTTI Cultures', bio: "Président de l’association FOTTI Cultures, structure porteuse du festival.", photo: null, featured: false },
  { ini: 'OS', name: 'Oumou Sy', role: 'Présidente d’honneur', bio: "Styliste et scénographe de renommée internationale, figure emblématique de la création africaine.", photo: null, featured: false },
  { ini: 'SB', name: 'Selly Ba', role: 'Sponsors & partenariats', bio: '', photo: null, featured: false },
];
const team = cmsTeam.length ? cmsTeam.map(mapPerson) : fallbackTeam;
const founder = team.find((m) => m.featured) || null;
const others = team.filter((m) => m !== founder);

// Partenaires (Strapi `partner`) avec repli.
const partRes = await fetchAPI('partners', { populate: 'logo', sort: 'order:asc' });
const fallbackPartners = [
  { name: 'Wallonie-Bruxelles Int.', url: 'https://www.wbi.be', logo: '/partenaires/wallonie-bruxelles.jpg' },
  { name: 'Alliance Française', url: '#', logo: '/partenaires/alliance-francaise.jpg' },
  { name: 'Air Sénégal', url: 'https://flyairsenegal.com', logo: '/partenaires/air-senegal.jpg' },
  { name: 'FOTTI', url: '#', logo: '/partenaires/fotti.jpg' },
  { name: 'LONASE', url: 'https://www.lonase.sn', logo: '/partenaires/lonase.jpg' },
  { name: 'TALAATA Production', url: '#', logo: '/partenaires/talaata.jpg' },
];
const cmsPartnersMapped = (partRes.data || []).map((p) => ({ name: p.name, url: p.url || '#', logo: p.logo?.url ? mediaUrl(p.logo.url) : null }));
// Strapi seul dès qu'il y a au moins 1 partenaire ; sinon logos de démo.
const partners = cmsPartnersMapped.length ? cmsPartnersMapped : fallbackPartners;

const objectifs = [
  { num: '— 01', icon: '🎬', title: 'Promotion du cinéma africain', desc: 'Faire rayonner les talents et les récits du continent, et rendre le cinéma africain désirable auprès d’un large public : jeunes, familles, étudiants.' },
  { num: '— 02', icon: '🎥', title: 'Augmentation du potentiel cinématographique de la Casamance', desc: 'Stimuler la venue de tournages nationaux et internationaux et proposer une offre de cinéma dans et pour la ville de Ziguinchor.' },
  { num: '— 03', icon: '🎓', title: 'Développement de la formation des jeunes professionnels', desc: 'Renforcer la formation et l’emploi des talents locaux, dans la continuité de l’Académie Cinéma de FOTTI Cultures.' },
  { num: '— 04', icon: '🌍', title: 'Stimulation de l’économie locale par le tourisme culturel', desc: 'Soutenir l’économie casamançaise et faire rayonner l’image de marque « Casamance » comme levier de soft power et de développement touristique.' },
];
---
<Base title="Le ZIFFA — Présentation, objectifs & équipe" description="Présentation officielle du ZIFFA, ses objectifs, son équipe, la presse, les partenaires et les archives.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; Le ZIFFA</div>
      <div class="eyebrow"><span class="arrow">→</span> Découvrir le festival</div>
      <h1>Le <span class="yellow">ZIFFA</span>.</h1>
      <p>Le Ziguinchor International Film Festival &amp; Animation célèbre le cinéma africain en Casamance.</p>
    </div>
  </header>

  <!-- ===== HISTOIRE / PRÉSENTATION ===== -->
  <section class="section" id="histoire">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="arrow">→</span> Présentation du festival</div>
        <h2 class="section-title">Présentation<br />du <span class="red">festival</span>.</h2>
      </div>
      <a href="#" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Document officiel ↓</a>
    </div>
    <p class="lead" style="margin-bottom:36px;">Découvrez l'univers du ZIFFA à travers notre document de présentation officiel.</p>

    <div class="presentation-editorial" style="max-width:880px;">
      <p>Ce festival de cinéma ambitionne de faire rayonner la région de Ziguinchor à travers une programmation artistique <strong>panafricaine et internationale</strong>, tout en valorisant la diversité culturelle, la créativité des jeunes, et le potentiel du Sud du Sénégal dans le domaine des industries culturelles et créatives.</p>
      <p>Une attention particulière sera portée à la <strong>jeunesse</strong>, avec une programmation dédiée incluant un atelier de stop motion de 12 jours, des séances de conte, ainsi que des projections spéciales.</p>
      <p>Avant le coup d'envoi du festival, place à <strong>douze jours d'ateliers intensifs</strong> ouverts aux professionnels et aux jeunes !</p>
    </div>
  </section>

  <!-- ===== OBJECTIFS DU FESTIVAL ===== -->
  <section class="objectifs-section" id="valeurs">
    <div class="objectifs-inner">
      <div class="objectifs-header">
        <div class="eyebrow"><span class="arrow">→</span> Notre mission</div>
        <h2 class="section-title">Objectifs du <span class="yellow-highlight">festival</span>.</h2>
        <p class="objectifs-tagline">Promouvoir le cinéma africain et développer l'industrie cinématographique en Casamance.</p>
      </div>
      <div class="objectifs-grid">
        {objectifs.map((o, i) => (
          <div class={`objectif-card objectif-card--filled oc-${['red', 'green', 'yellow', 'orange'][i % 4]}`}>
            <div class="objectif-num">{o.num}</div>
            <h3>{o.title}</h3>
            <p>{o.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ÉQUIPE ===== -->
  <section class="section" id="equipe">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Celles & ceux qui font le festival</div><h2 class="section-title">L'<span class="italic">équipe</span>.</h2></div></div>

    <div class="team-grid">
      {team.map((m) => (
        <button type="button" class={`team-portrait js-person ${m.featured ? 'team-portrait--focus' : ''}`} data-name={m.name} data-role={m.role} data-bio={m.bio} data-photo={m.photo || ''} data-ini={m.ini}>
          <div class="team-photo" style={m.photo ? `background-image:url('${m.photo}')` : ''}>{m.photo ? '' : <span class="team-ini">{m.ini}</span>}{m.featured && <span class="team-badge">★ Fondateur</span>}</div>
          <div class="team-info"><div class="team-name">{m.name}</div><div class="team-role">{m.role}</div></div>
        </button>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ===== PRESSE ===== -->
  <section class="section" id="presse">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Espace presse</div><h2 class="section-title">Kit <span class="red">presse</span>.</h2></div><a href="/presse" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Accéder à l'espace presse →</a></div>
    <p class="lead" style="max-width:760px;margin-bottom:30px;">Toutes les ressources presse du ZIFFA, à télécharger une par une, par sélection ou en lot.</p>
    <div class="presse-cards">
      <a class="presse-card pc-red" href="/presse/dossier"><span class="presse-ic">📄</span><h3>Dossier de presse</h3><p>Présentation, chiffres clés et contacts.</p><span class="presse-go">Accéder →</span></a>
      <a class="presse-card pc-green" href="/presse/logos"><span class="presse-ic">🎨</span><h3>Logos & charte</h3><p>Logos (couleur, blanc) et règles d'usage.</p><span class="presse-go">Accéder →</span></a>
      <a class="presse-card pc-yellow" href="/presse/photos"><span class="presse-ic">📸</span><h3>Photothèque</h3><p>Photos haute définition pour la presse.</p><span class="presse-go">Accéder →</span></a>
    </div>
  </section>

  <!-- ===== PARTENAIRES ===== -->
  <section class="partners-section" id="partenaires">
    <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Soutiens & Partenaires</div>
    <h2 class="section-title" style="margin:16px auto 0;max-width:700px;">Ils <span class="red">accompagnent</span><br />le ZIFFA.</h2>
    <p class="partners-intro">Le festival est rendu possible grâce au soutien d'institutions et de partenaires engagés.</p>
    <div class="partners-marquee">
      <div class="partners-marquee-track">
        {partners.map((p) => (
          <a href={p.url} target="_blank" rel="noopener" class="partner-logo" title={p.name}>
            {p.logo && <img src={p.logo} alt={p.name} />}
            <span class="partner-logo-name">{p.name}</span>
          </a>
        ))}
        {partners.map((p) => (
          <a href={p.url} target="_blank" rel="noopener" class="partner-logo" aria-hidden="true" tabindex="-1">
            {p.logo && <img src={p.logo} alt="" />}
            <span class="partner-logo-name">{p.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== ARCHIVES ===== -->
  <section class="section" id="archives">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Mémoire du festival</div><h2 class="section-title">Les <span class="italic">archives</span>.</h2></div></div>
    <div class="archive-cards">
      <a class="archive-card" href="/edition-2025">
        <div class="archive-head archive-head--past"><span class="archive-num">— Édition 01</span><span class="archive-year">2025</span></div>
        <div class="archive-body"><p>Retour en images, palmarès et programme de la première édition.</p><span class="archive-link">Revivre 2025 ↗</span></div>
      </a>
      <a class="archive-card" href="/edition-2027">
        <div class="archive-head archive-head--next"><span class="archive-num">— Prochaine édition</span><span class="archive-year">2027</span></div>
        <div class="archive-body"><p>Programme, jurys, prix et masterclasses à venir.</p><span class="archive-link">Découvrir 2027 ↗</span></div>
      </a>
    </div>
  </section>

  <!-- Popup profil personne -->
  <div class="person-modal" id="person-modal" hidden>
    <div class="pm-backdrop" data-close></div>
    <div class="pm-dialog" role="dialog" aria-modal="true" aria-labelledby="pm-name">
      <button class="pm-close" data-close aria-label="Fermer">×</button>
      <div class="pm-photo" id="pm-photo"></div>
      <div class="pm-body">
        <div class="pm-role" id="pm-role"></div>
        <h3 id="pm-name"></h3>
        <p id="pm-bio"></p>
      </div>
    </div>
  </div>
</Base>

<script>
  const modal = document.getElementById('person-modal');
  if (modal) {
    const pmPhoto = document.getElementById('pm-photo');
    const pmName = document.getElementById('pm-name');
    const pmRole = document.getElementById('pm-role');
    const pmBio = document.getElementById('pm-bio');
    const pmClose = modal.querySelector('.pm-close');
    let pmLast = null;
    const open = (d) => {
      pmName.textContent = d.name || '';
      pmRole.textContent = d.role || '';
      pmBio.textContent = d.bio || '';
      if (d.photo) { pmPhoto.style.backgroundImage = `url('${d.photo}')`; pmPhoto.textContent = ''; pmPhoto.classList.remove('pm-photo--ini'); }
      else { pmPhoto.style.backgroundImage = ''; pmPhoto.textContent = d.ini || ''; pmPhoto.classList.add('pm-photo--ini'); }
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      pmLast = document.activeElement;
      pmClose.focus();
    };
    const close = () => { modal.hidden = true; document.body.style.overflow = ''; if (pmLast && pmLast.focus) pmLast.focus(); };
    document.querySelectorAll('.js-person').forEach((c) => c.addEventListener('click', () => open(c.dataset)));
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (modal.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'Tab') { e.preventDefault(); pmClose.focus(); }
    });
  }
</script>
