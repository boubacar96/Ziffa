---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl, altPath } from '../i18n.js';
import '../styles/style.css';

const { title = 'ZIFFA', description = '' } = Astro.props;
const lang = getLangFromUrl(Astro.url);
// URLs absolues (fonctionnent en local, sur le serveur et avec le domaine).
const ogImage = new URL('/photos/photo06.jpg', Astro.url).href;
const canonical = Astro.url.href;
const frUrl = new URL(altPath(Astro.url, 'fr'), Astro.url).href;
const enUrl = new URL(altPath(Astro.url, 'en'), Astro.url).href;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="fr" href={frUrl} />
  <link rel="alternate" hreflang="en" href={enUrl} />
  <link rel="alternate" hreflang="x-default" href={frUrl} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/ziffa.png" />
  <link rel="apple-touch-icon" href="/ziffa.png" />
  <meta name="theme-color" content="#1A4527" />

  <!-- Partage réseaux (OpenGraph + Twitter) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="ZIFFA" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Préconnexions pour charger plus vite les polices et les médias -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://admin.ziffa.sn" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <a href="#main" class="skip-link">{lang === 'en' ? 'Skip to content' : 'Aller au contenu'}</a>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />

  <script>
    (() => {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Apparition au scroll (progressif : rien n'est masqué si JS off)
      if (!reduce && 'IntersectionObserver' in window) {
        document.documentElement.classList.add('js-reveal');
        const sel = '.section-head, .film-card, .objectif-card, .prize-card, .prize-photo, .team-portrait, .archive-card, .presse-card, .film-sel-card, .film-poster-card, .hl-card, .programme-event, .atelier-card, .stat-card, .ed-card, .partner-logo, .download-row, .gallery-grid figure, .cd-box, .timeline-item, .tier-card, .presentation-editorial';
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('revealed'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll(sel).forEach((el) => { el.classList.add('reveal-el'); io.observe(el); });
      }

      // Lightbox galeries — navigation ‹ ›, clavier, légende
      const GAL_SEL = '.gallery-grid img, .gallery-marquee img, .gallery-page img';
      const lb = document.createElement('div');
      lb.className = 'lightbox';
      lb.setAttribute('role', 'dialog');
      lb.setAttribute('aria-modal', 'true');
      lb.setAttribute('aria-label', document.documentElement.lang === 'en' ? 'Image viewer' : 'Visionneuse d’images');
      lb.innerHTML = '<button class="lightbox-close" aria-label="Fermer">✕</button>'
        + '<button class="lightbox-prev" aria-label="Précédent">‹</button>'
        + '<figure class="lightbox-fig"><img alt=""><figcaption class="lightbox-caption"></figcaption></figure>'
        + '<button class="lightbox-next" aria-label="Suivant">›</button>';
      document.body.appendChild(lb);
      let lbLastFocus = null;
      const lbImg = lb.querySelector('img');
      const lbCap = lb.querySelector('.lightbox-caption');
      const prevBtn = lb.querySelector('.lightbox-prev');
      const nextBtn = lb.querySelector('.lightbox-next');
      let imgs = [];
      let idx = 0;
      const collect = () => {
        const seen = new Set(); imgs = [];
        document.querySelectorAll(GAL_SEL).forEach((im) => {
          const s = im.currentSrc || im.src;
          if (!seen.has(s)) { seen.add(s); imgs.push(im); }
        });
      };
      const render = () => {
        const im = imgs[idx]; if (!im) return;
        lbImg.src = im.currentSrc || im.src;
        const cap = im.getAttribute('alt') || '';
        lbCap.textContent = cap; lbCap.style.display = cap ? '' : 'none';
        const multi = imgs.length > 1;
        prevBtn.style.display = nextBtn.style.display = multi ? '' : 'none';
      };
      const go = (d) => { idx = (idx + d + imgs.length) % imgs.length; render(); };
      const closeBtn = lb.querySelector('.lightbox-close');
      const openAt = (el) => {
        collect();
        const s = el.currentSrc || el.src;
        idx = Math.max(0, imgs.findIndex((x) => (x.currentSrc || x.src) === s));
        render(); lb.classList.add('open'); document.body.style.overflow = 'hidden';
        lbLastFocus = document.activeElement;
        closeBtn.focus();
      };
      const close = () => {
        lb.classList.remove('open'); document.body.style.overflow = '';
        if (lbLastFocus && lbLastFocus.focus) lbLastFocus.focus();
      };
      closeBtn.addEventListener('click', close);
      prevBtn.addEventListener('click', (e) => { e.stopPropagation(); go(-1); });
      nextBtn.addEventListener('click', (e) => { e.stopPropagation(); go(1); });
      lb.addEventListener('click', (e) => { if (e.target === lb || e.target.classList.contains('lightbox-fig')) close(); });
      document.addEventListener('keydown', (e) => {
        if (!lb.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') go(-1);
        else if (e.key === 'ArrowRight') go(1);
        else if (e.key === 'Tab') {
          // Piège de focus : on reste sur les boutons visibles du lightbox
          const f = [closeBtn, prevBtn, nextBtn].filter((b) => b.style.display !== 'none');
          const i = f.indexOf(document.activeElement);
          e.preventDefault();
          const ni = e.shiftKey ? (i <= 0 ? f.length - 1 : i - 1) : (i >= f.length - 1 ? 0 : i + 1);
          f[ni].focus();
        }
      });
      document.querySelectorAll(GAL_SEL).forEach((img) => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => openAt(img));
      });
    })();
  </script>
</body>
</html>
