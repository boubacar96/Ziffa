---
import Base from '../layouts/Base.astro';

// --- Mosaïque du hero (générée pour varier formes et photos) ---
const shapes = ['tall', 'square', 'wide'];
const heroCols = Array.from({ length: 6 }, (_, c) =>
  Array.from({ length: 10 }, (_, i) => ({
    n: String(((c * 3 + i * 2) % 10) + 1).padStart(2, '0'),
    shape: shapes[(c + i) % 3],
  }))
);

// --- À l'affiche (contenu de démo, à brancher sur Strapi ensuite) ---
const films = [
  { title: 'Sous le Baobab', cat: 'Fiction', meta: 'Aïssatou Diop · Sénégal · 2025' },
  { title: 'Voix de Casamance', cat: 'Documentaire', meta: 'Mamadou Ba · 88 min' },
  { title: "L'Esprit du Fleuve", cat: 'Animation', meta: 'Studio Téranga · 2026' },
  { title: 'Le Dernier Griot', cat: 'Fiction', meta: 'Fatou Sow · Mali' },
  { title: 'Nuit à Ziguinchor', cat: 'Court-métrage', meta: 'O. Diédhiou · 18 min' },
  { title: "Mémoires d'Afrique", cat: 'Documentaire', meta: 'Collectif Casamance' },
];

// --- Pellicule (photos défilantes) ---
const stripPhotos = Array.from({ length: 10 }, (_, i) => String(i + 1).padStart(2, '0'));
---
<Base
  title="ZIFFA 2026 — Ziguinchor International Film Festival & Animation"
  description="Le rendez-vous du cinéma africain en Casamance — 12 au 15 novembre 2026."
>
  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero-mosaic">
      {heroCols.map((cards, idx) => (
        <div class={`mosaic-col mosaic-col-${idx + 1}`}>
          {cards.map((card) => (
            <div class={`mosaic-card ${card.shape}`}><img src={`/photos/photo${card.n}.jpg`} alt="" /></div>
          ))}
        </div>
      ))}
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-inner">
      <h1 class="hero-acronym">ZIFFA<span class="red-dot">.</span></h1>
      <div class="hero-full-name">
        <strong>Z</strong>iguinchor &nbsp;·&nbsp; <strong>I</strong>nternational &nbsp;·&nbsp;
        <strong>F</strong>ilm &nbsp;·&nbsp; <strong>F</strong>estival &nbsp;·&nbsp; <strong>&amp; A</strong>nimation
      </div>
      <h2 class="hero-subtitle">
        Le premier festival international de cinéma<br />
        et d'animation en <span class="yellow">Casamance</span>.
      </h2>
      <div class="hero-disciplines">
        <span class="discipline-pill">Long métrage</span>
        <span class="discipline-pill">Court métrage</span>
        <span class="discipline-pill">Animation</span>
        <span class="discipline-pill">Photographie</span>
      </div>
      <div class="hero-actions">
        <a href="/edition-2026" class="btn-primary">Découvrir l'édition 2026 →</a>
        <a href="/participer#inscription" class="btn-ghost">▶ Inscrire un film</a>
      </div>
    </div>
  </section>

  <!-- ===== 2. COMPTE À REBOURS ===== -->
  <section class="countdown-section">
    <div class="countdown-inner">
      <div class="eyebrow"><span class="arrow">→</span> Ouverture le 12 novembre 2026 · Ziguinchor</div>
      <h2 class="section-title">Plus que <span class="yellow">quelques jours</span>.</h2>
      <div class="countdown" id="countdown">
        <div class="cd-box"><span class="cd-num" data-cd="days">—</span><span class="cd-label">Jours</span></div>
        <div class="cd-box"><span class="cd-num" data-cd="hours">—</span><span class="cd-label">Heures</span></div>
        <div class="cd-box"><span class="cd-num" data-cd="mins">—</span><span class="cd-label">Minutes</span></div>
        <div class="cd-box"><span class="cd-num" data-cd="secs">—</span><span class="cd-label">Secondes</span></div>
      </div>
    </div>
  </section>

  <!-- ===== 3. LE FESTIVAL EN BREF ===== -->
  <section class="section">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="arrow">→</span> Le festival</div>
        <h2 class="section-title">Le cinéma africain,<br /><span class="red">en Casamance</span>.</h2>
      </div>
    </div>
    <p class="lead" style="margin-bottom:10px;">
      Le ZIFFA célèbre la création cinématographique et l'animation du continent et de sa diaspora :
      quatre jours de projections, de rencontres et de transmission, ouverts à tous.
    </p>
    <div class="brief-stats">
      <div class="stat-card stat-card-red">
        <div class="stat-card-content">
          <div class="stat-card-num">4<span class="plus">j</span></div>
          <div class="stat-card-label">de festival</div>
        </div>
      </div>
      <div class="stat-card stat-card-green">
        <div class="stat-card-content">
          <div class="stat-card-num">40<span class="plus">+</span></div>
          <div class="stat-card-label">films projetés</div>
        </div>
      </div>
      <div class="stat-card stat-card-yellow">
        <div class="stat-card-content">
          <div class="stat-card-num">10<span class="plus">+</span></div>
          <div class="stat-card-label">pays représentés</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 4. À L'AFFICHE ===== -->
  <section class="section" style="padding-top:0;">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="arrow">→</span> Sélection officielle</div>
        <h2 class="section-title">À l'<span class="italic">affiche</span>.</h2>
      </div>
      <a href="/edition-2026" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Toute la sélection →</a>
    </div>
    <div class="film-grid">
      {films.map((f) => (
        <article class="film-card">
          <div class="film-poster"><span class="film-cat">{f.cat}</span></div>
          <div class="film-body">
            <h3 class="film-title">{f.title}</h3>
            <div class="film-meta">{f.meta}</div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ===== 5. PROGRAMME EN UN COUP D'ŒIL ===== -->
  <section class="programme-section">
    <div class="programme-inner">
      <div style="text-align:center;margin-bottom:30px;">
        <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Programme · Édition 2026</div>
        <h2 class="section-title" style="margin:12px auto;text-align:center;">Quatre jours<br />de <span class="red">temps forts</span>.</h2>
      </div>
      <div class="programme-event" data-type="ceremonie">
        <div class="programme-event-time">Jeu 12</div>
        <div class="programme-event-info"><h4>Cérémonie d'ouverture & film inaugural</h4><p>Le coup d'envoi du festival, en présence des invités.</p></div>
        <div class="programme-event-location"><span class="programme-event-type event-type-ceremonie">Cérémonie</span><strong>Théâtre Aline Sitoé Diatta</strong></div>
        <div class="programme-event-arrow">→</div>
      </div>
      <div class="programme-event" data-type="projection">
        <div class="programme-event-time">Ven 13</div>
        <div class="programme-event-info"><h4>Projections en compétition</h4><p>Fictions, documentaires et animations de la sélection.</p></div>
        <div class="programme-event-location"><span class="programme-event-type event-type-projection">Projections</span><strong>Salle Casamance</strong></div>
        <div class="programme-event-arrow">→</div>
      </div>
      <div class="programme-event" data-type="masterclass">
        <div class="programme-event-time">Sam 14</div>
        <div class="programme-event-info"><h4>Masterclasses & rencontres pro</h4><p>Transmission avec les cinéastes invités.</p></div>
        <div class="programme-event-location"><span class="programme-event-type event-type-masterclass">Masterclass</span><strong>Institut français</strong></div>
        <div class="programme-event-arrow">→</div>
      </div>
      <div class="programme-event" data-type="ceremonie">
        <div class="programme-event-time">Dim 15</div>
        <div class="programme-event-info"><h4>Cérémonie de clôture & palmarès</h4><p>Remise des prix de l'édition 2026.</p></div>
        <div class="programme-event-location"><span class="programme-event-type event-type-ceremonie">Cérémonie</span><strong>Théâtre Aline Sitoé Diatta</strong></div>
        <div class="programme-event-arrow">→</div>
      </div>
      <div style="text-align:center;margin-top:36px;">
        <a href="/edition-2026#programme" class="nav-cta" style="background:var(--red);">Programme complet ↗</a>
      </div>
    </div>
  </section>

  <!-- ===== 6. BANDE-ANNONCE ===== -->
  <section class="video-2025-section">
    <div class="video-2025-inner">
      <div class="video-2025-head">
        <div class="eyebrow"><span class="arrow">→</span> Teaser officiel</div>
        <h2 class="section-title">ZIFFA <span class="red">2026</span><br />en <span class="italic">mouvement</span>.</h2>
        <p>Un avant-goût du festival : l'énergie, les images, l'émotion du cinéma africain.</p>
      </div>
      <div class="video-wrapper" onclick="this.querySelector('.video-placeholder')?.classList.add('played')">
        <div class="video-placeholder">
          <div class="play-button"></div>
          <div class="video-info">
            <div class="video-info-label">— Teaser · 02:00</div>
            <div class="video-info-title">ZIFFA <em>2026</em> — Bande-annonce</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 7. GALERIE / PELLICULE ===== -->
  <section class="filmstrip-section">
    <div class="section-head">
      <div>
        <div class="eyebrow"><span class="arrow">→</span> En images</div>
        <h2 class="section-title">Une fête du <span class="red">cinéma</span>.</h2>
      </div>
      <a href="/edition-2025#images" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Toute la galerie →</a>
    </div>
    <div class="filmstrip">
      <div class="filmstrip-track">
        {stripPhotos.map((n) => (
          <figure><img src={`/photos/photo${n}.jpg`} alt="ZIFFA — temps fort" loading="lazy" /></figure>
        ))}
        {stripPhotos.map((n) => (
          <figure aria-hidden="true"><img src={`/photos/photo${n}.jpg`} alt="" loading="lazy" /></figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 8. PARTENAIRES ===== -->
  <section class="partners-section" id="partenaires">
    <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Soutiens & Partenaires</div>
    <h2 class="section-title" style="margin:16px auto 0;max-width:700px;">Ils <span class="red">accompagnent</span><br />le ZIFFA.</h2>
    <p class="partners-intro">Le festival est rendu possible grâce au soutien d'institutions et de partenaires engagés pour le cinéma africain.</p>
    <div class="partners-grid">
      <a href="https://www.wbi.be" target="_blank" rel="noopener" class="partner-logo"><img src="/partenaires/wallonie-bruxelles.jpg" alt="Wallonie-Bruxelles International" /><span class="partner-logo-name">Wallonie-Bruxelles Int.</span></a>
      <a href="#" class="partner-logo"><img src="/partenaires/alliance-francaise.jpg" alt="Alliance Française" /><span class="partner-logo-name">Alliance Française</span></a>
      <a href="https://flyairsenegal.com" target="_blank" rel="noopener" class="partner-logo"><img src="/partenaires/air-senegal.jpg" alt="Air Sénégal" /><span class="partner-logo-name">Air Sénégal</span></a>
      <a href="#" class="partner-logo"><img src="/partenaires/fotti.jpg" alt="FOTTI" /><span class="partner-logo-name">FOTTI</span></a>
      <a href="https://www.lonase.sn" target="_blank" rel="noopener" class="partner-logo"><img src="/partenaires/lonase.jpg" alt="LONASE" /><span class="partner-logo-name">LONASE</span></a>
      <a href="#" class="partner-logo"><img src="/partenaires/talaata.jpg" alt="TALAATA Production" /><span class="partner-logo-name">TALAATA Production</span></a>
    </div>
    <a href="/participer#partenariat" class="btn-ghost">Devenir partenaire →</a>
  </section>

  <!-- ===== 9. NEWSLETTER ===== -->
  <section class="newsletter" id="newsletter">
    <div class="newsletter-inner">
      <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Newsletter</div>
      <h2>Ne ratez <span class="red">rien</span><br />du <span class="italic">festival</span>.</h2>
      <p>Programmes, appels à films, annonces de jurys, coulisses : recevez l'actualité du ZIFFA dans votre boîte mail.</p>
      <form class="newsletter-form" onsubmit="event.preventDefault(); alert('Merci pour votre inscription !'); this.reset();">
        <input type="email" placeholder="votre@email.com" required />
        <button type="submit">S'inscrire ↗</button>
      </form>
    </div>
  </section>
</Base>

<script>
  // Compte à rebours jusqu'à l'ouverture du festival.
  const target = new Date('2026-11-12T19:00:00').getTime();
  function pad(n) { return String(n).padStart(2, '0'); }
  function tick() {
    const diff = target - Date.now();
    const set = (k, v) => { const el = document.querySelector(`[data-cd="${k}"]`); if (el) el.textContent = v; };
    if (diff <= 0) { set('days', '0'); set('hours', '00'); set('mins', '00'); set('secs', '00'); return; }
    set('days', String(Math.floor(diff / 86400000)));
    set('hours', pad(Math.floor((diff % 86400000) / 3600000)));
    set('mins', pad(Math.floor((diff % 3600000) / 60000)));
    set('secs', pad(Math.floor((diff % 60000) / 1000)));
  }
  tick();
  setInterval(tick, 1000);
</script>
