---
import Base from '../../layouts/Base.astro';
---
<Base title="Take part | ZIFFA" description="Take part in ZIFFA 2027: submit a film, get accredited, become a partner.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; Take part</div>
      <div class="eyebrow"><span class="arrow">→</span> Join us</div>
      <h1>Be part of<br />the <span class="yellow">ZIFFA</span>.</h1>
      <p>Filmmakers, professionals, journalists and partners: three ways to take part in the 2027 edition.</p>
    </div>
  </header>
  <section class="section" id="inscription">
    <p class="lead">Film submission, accreditation and partnership forms — coming soon. In the meantime, reach us via the <a href="/en/contact#contact" style="color:var(--red);">Contact</a> page.</p>
  </section>
  <section class="section" id="accreditation"></section>
  <section class="section" id="partenariat"></section>
</Base>
