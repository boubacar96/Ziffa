---
import { getLangFromUrl, useTranslations, lp } from '../i18n.js';
import { NAV } from '../lib/nav.js';
import Socials from './Socials.astro';
import { getGlobal } from '../lib/strapi.js';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p) => lp(p, lang);
const g = await getGlobal();
const socialLinks = { facebook: g.facebook || '#', instagram: g.instagram || '#', linkedin: g.linkedin || '#', youtube: g.youtube || '#' };
const address = g.address || 'Ziguinchor, Casamance — Sénégal';
---
<footer>
  <div class="footer-top">
    <div class="footer-brand">
      <img src="/talaata-white.png" alt="TALAATA Production" class="footer-logo" width="200" height="75" />
      <p class="footer-legal" style="font-size:13px;line-height:1.8;letter-spacing:0.2px;">
        Société à responsabilité limitée<br />
        au capital de 1.000.000 francs CFA<br />
        Siège social : Cité Diamalaye II, Villa Numéro 71TE (Sénégal)<br />
        RC : SN.DKR.2018.B.21407
      </p>
      <div class="footer-contact-line">{address}</div>
      <Socials links={socialLinks} />

      <form class="footer-news" id="footer-news" data-ok={lang === 'en' ? "✓ Thanks, you're subscribed!" : '✓ Merci, inscription enregistrée !'}>
        <div class="footer-news-label">{t('nav.newsletter')}</div>
        <div class="footer-news-row">
          <input type="email" name="email" placeholder={lang === 'en' ? 'your@email.com' : 'votre@email.com'} required aria-label={t('nav.newsletter')} />
          <button type="submit" aria-label="OK">→</button>
        </div>
        <input type="hidden" name="type" value="newsletter" />
        <span class="hp"><input type="text" name="website" tabindex="-1" autocomplete="off" /></span>
        <div class="footer-news-msg" id="footer-news-msg"></div>
      </form>
    </div>

    <nav class="footer-nav" aria-label="Pied de page">
      {NAV.map((g) => (
        <div class="footer-col">
          <h4>{g.href ? <a href={L(g.href)}>{t(g.key)}</a> : t(g.key)}</h4>
          {g.items.length > 0 && (
            <ul>
              {g.items.map((i) => (
                <li><a href={L(i.href)}>{i.label ? i.label[lang] : t(i.key)}</a></li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </nav>
  </div>

  <div class="footer-copy">
    <div>{t('footer.rights')}</div>
    <div>Ziguinchor International Film Festival &amp; Animation</div>
  </div>
</footer>

<script>
  const fn = document.getElementById('footer-news');
  if (fn) {
    const msg = document.getElementById('footer-news-msg');
    fn.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (fn.querySelector('input[name="website"]').value) return;
      if (!fn.checkValidity()) { fn.reportValidity && fn.reportValidity(); return; }
      const btn = fn.querySelector('button'); btn.disabled = true;
      try {
        const res = await fetch('/api/contact-submission', { method: 'POST', body: new FormData(fn) });
        const data = await res.json();
        msg.textContent = data.ok ? (fn.dataset.ok || '✓') : ('⚠️ ' + (data.error || 'Erreur.'));
        if (data.ok) fn.reset();
      } catch (err) { msg.textContent = '⚠️ Échec, réessayez.'; }
      finally { btn.disabled = false; }
    });
  }
</script>
