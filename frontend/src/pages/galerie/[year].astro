---
import Base from '../../layouts/Base.astro';
import { fetchAPI, mediaUrl, mediaUrls } from '../../lib/strapi.js';
const { year } = Astro.params;
const res = await fetchAPI('photos', { 'filters[edition][year][$eq]': year, populate: 'image', 'pagination[limit]': '200' });
const cms = (res.data || []).flatMap((p) => mediaUrls(p.image));
const fallback = Array.from({ length: 12 }, (_, i) => `/photos/photo${String(i + 1).padStart(2, '0')}.jpg`);
const photos = cms.length ? cms : fallback;
---
<Base title={`Galerie ${year} | ZIFFA`} description={`Galerie photos de l'édition ${year} du ZIFFA.`}>
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; <a href={`/edition-${year}`}>Édition {year}</a> &nbsp;/&nbsp; Galerie</div>
      <div class="eyebrow"><span class="arrow">→</span> En images · {year}</div>
      <h1>Galerie <span class="yellow">{year}</span>.</h1>
      <p>Revivez l'édition {year} du ZIFFA en images. Cliquez sur une photo pour l'agrandir.</p>
    </div>
  </header>

  <section class="section">
    <div class="gallery-grid">
      {photos.map((src, i) => (
        <figure class={i % 5 === 0 ? 'tall' : ''}><img src={src} alt={`ZIFFA ${year}`} loading="lazy" decoding="async" /></figure>
      ))}
    </div>
    <div style="text-align:center;margin-top:36px;">
      <a href={`/edition-${year}`} class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">← Retour à l'édition {year}</a>
    </div>
  </section>
</Base>
