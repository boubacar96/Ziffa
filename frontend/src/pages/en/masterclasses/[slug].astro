---
import Base from '../../../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../../../lib/strapi.js';
import { toVideoEmbed } from '../../../lib/formations.js';
import { fallbackMasterclasses } from '../../../lib/masterclasses.js';
import { marked } from 'marked';

const { slug } = Astro.params;
const res = await fetchAPI('masterclasses', { 'filters[slug][$eq]': slug, populate: '*', 'pagination[limit]': '1' });
const f = (res.data || [])[0];
let mc = null;
if (f) {
  mc = {
    title: f.title, excerpt: f.excerpt || '', content: f.content || '',
    location: f.location || '', participants: f.participants || '', duration: f.duration || '',
    quote: f.quote || '', quoteAuthor: f.quoteAuthor || '', reportageUrl: f.reportageUrl || '',
    cover: f.cover?.url ? mediaUrl(f.cover.url) : null,
    gallery: (f.gallery || []).map((g) => (g.url ? mediaUrl(g.url) : null)).filter(Boolean),
    videos: (f.videos || []).map((v) => ({ title: v.title || '', url: toVideoEmbed(v.url) })),
  };
} else {
  const fb = fallbackMasterclasses('en').find((x) => x.slug === slug);
  if (fb) mc = { ...fb, videos: (fb.videos || []).map((v) => ({ title: v.title, url: toVideoEmbed(v.url) })) };
}
const meta = mc ? [
  mc.location && { icon: '📍', label: 'Venue', value: mc.location },
  mc.participants && { icon: '👥', label: 'Attendees', value: mc.participants },
  mc.duration && { icon: '⏱️', label: 'Duration', value: mc.duration },
].filter(Boolean) : [];
const contentHtml = mc ? marked.parse(mc.content || '') : '';
const coverStyle = mc && mc.cover
  ? `background-image:linear-gradient(rgba(26,69,39,.55),rgba(26,69,39,.85)),url('${mc.cover}')`
  : '';
---
<Base title={mc ? `${mc.title} | ZIFFA masterclass` : 'Masterclass | ZIFFA'} description={mc?.excerpt || ''}>
  {mc ? (
    <>
      <header class="formation-hero" style={coverStyle}>
        <div class="formation-hero-inner">
          <nav class="formation-crumb"><a href="/en">Home</a><span>›</span><a href="/en/edition-2025">2025 edition</a><span>›</span><a href="/en/edition-2025#masterclasses">Masterclasses</a></nav>
          <span class="formation-tag">Masterclass</span>
          <h1>{mc.title}</h1>
          {mc.excerpt && <p>{mc.excerpt}</p>}
        </div>
      </header>

      <article class="section formation-article">
        {meta.length > 0 && (
          <div class="mc-meta">
            {meta.map((m) => (
              <div class="mc-meta-item">
                <span class="mc-meta-ic">{m.icon}</span>
                <span class="mc-meta-k">{m.label}</span>
                <span class="mc-meta-v">{m.value}</span>
              </div>
            ))}
          </div>
        )}

        {contentHtml && <div class="formation-prose" set:html={contentHtml}></div>}

        {mc.quote && (
          <blockquote class="mc-quote">
            <p>“{mc.quote}”</p>
            {mc.quoteAuthor && <cite>— {mc.quoteAuthor}</cite>}
          </blockquote>
        )}

        {mc.reportageUrl && (
          <div class="mc-reportage">
            <a href={mc.reportageUrl} target="_blank" rel="noopener" class="nav-cta">▶ Watch the report ↗</a>
          </div>
        )}

        {mc.gallery.length > 0 && (
          <section class="formation-block">
            <h2 class="formation-block-title">In pictures</h2>
            <div class="gallery-grid">
              {mc.gallery.map((src) => (<figure><img src={src} alt={mc.title} loading="lazy" decoding="async" /></figure>))}
            </div>
          </section>
        )}

        {mc.videos.length > 0 && (
          <section class="formation-block">
            <h2 class="formation-block-title">Videos</h2>
            <div class="formation-videos">
              {mc.videos.map((v) => (
                <div class="formation-video">
                  <div class="video-wrapper"><iframe src={v.url} title={v.title || mc.title} allow="fullscreen; picture-in-picture" allowfullscreen loading="lazy" style="width:100%;height:100%;border:0;display:block;"></iframe></div>
                  {v.title && <div class="formation-video-title">{v.title}</div>}
                </div>
              ))}
            </div>
          </section>
        )}

      </article>
    </>
  ) : (
    <section class="section" style="text-align:center;padding:80px 20px;">
      <h1 class="section-title">404</h1>
      <p class="prog-pdf-empty" style="max-width:480px;margin:20px auto;">This masterclass could not be found.</p>
      <a href="/en/edition-2025#masterclasses" class="nav-cta">← Masterclasses</a>
    </section>
  )}
</Base>
