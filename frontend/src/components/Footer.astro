---
import { getLangFromUrl, useTranslations, lp } from '../i18n.js';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const L = (p) => lp(p, lang);
---
<footer>
  <div class="footer-top">
    <div class="footer-brand">
      <div class="footer-wordmark">TALAATA</div>
      <p class="footer-legal" style="font-size:13px;line-height:1.8;letter-spacing:0.2px;">
        Société à responsabilité limitée<br />
        au capital de 1.000.000 francs CFA<br />
        Siège social : Cité Diamalaye II, Villa Numéro 71TE (Sénégal)<br />
        RC : SN.DKR.2018.B.21407
      </p>
      <div class="footer-contact-line">
        <a href="mailto:contact@ziffa.sn">contact@ziffa.sn</a><span class="sep">·</span>+221 77 336 43 30<br />
        Ziguinchor, Casamance — Sénégal
      </div>
      <div class="socials">
        <a href="#" class="social-btn">Fb</a>
        <a href="#" class="social-btn">Ig</a>
        <a href="#" class="social-btn">In</a>
        <a href="#" class="social-btn">Yt</a>
      </div>
    </div>

    <div class="footer-map">
      <span class="footer-map-tag">📍 Ziguinchor</span>
      <iframe
        src="https://www.google.com/maps?q=Ziguinchor,+S%C3%A9n%C3%A9gal&z=13&output=embed"
        title="Carte — Ziguinchor, Sénégal"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </div>

  <div class="footer-grid">
    <div class="footer-col">
      <h4>{t('footer.festival')}</h4>
      <ul>
        <li><a href={L('/le-ziffa') + '#histoire'}>{t('footer.histoire')}</a></li>
        <li><a href={L('/le-ziffa') + '#valeurs'}>{t('footer.valeurs')}</a></li>
        <li><a href={L('/le-ziffa') + '#equipe'}>{t('footer.equipe')}</a></li>
        <li><a href={L('/le-ziffa') + '#archives'}>{t('footer.archives')}</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>{t('footer.ed2027')}</h4>
      <ul>
        <li><a href={L('/edition-2027') + '#programme'}>{t('nav.programme')}</a></li>
        <li><a href={L('/edition-2027') + '#prix'}>{t('nav.prix')}</a></li>
        <li><a href={L('/edition-2027') + '#jury'}>{t('nav.jury')}</a></li>
        <li><a href={L('/edition-2025') + '#images'}>{t('footer.galerie')}</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>{t('footer.participer')}</h4>
      <ul>
        <li><a href={L('/participer') + '#inscription'}>{t('nav.inscrire')}</a></li>
        <li><a href={L('/a-lannee')}>{t('footer.formations')}</a></li>
        <li><a href={L('/le-ziffa') + '#partenaires'}>{t('nav.partenaires')}</a></li>
        <li><a href={L('/contact') + '#contact'}>{t('footer.presse')}</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>{t('footer.infos')}</h4>
      <ul>
        <li><a href={L('/contact') + '#contact'}>{t('footer.contact')}</a></li>
        <li><a href={L('/contact') + '#newsletter'}>{t('nav.newsletter')}</a></li>
        <li><a href={L('/edition-2025')}>{t('footer.ed2025link')}</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div>{t('footer.rights')}</div>
    <div>Ziguinchor International Film Festival &amp; Animation</div>
  </div>
</footer>
