---
import Base from '../layouts/Base.astro';
import UnderConstruction from '../components/UnderConstruction.astro';
import { fetchAPI, mediaUrl } from '../lib/strapi.js';

// Formations depuis Strapi (type `formation`), avec repli.
const fRes = await fetchAPI('formations', { populate: 'image' });
const cms = fRes.data || [];
const doc = cms.find((f) => f.type === 'documentaire');
const anim = cms.find((f) => f.type === 'animation');
const formationDoc = {
  title: doc?.title || 'Formation documentaire',
  desc: doc?.description || "De l'idée au montage : construire un récit documentaire à partir du réel — repérage, tournage, entretien, écriture et post-production.",
  schedule: doc?.schedule || "Sessions sur l'année",
  level: doc?.level || 'Tous niveaux',
};
const formationAnim = {
  title: anim?.title || 'Formation animation',
  desc: anim?.description || "Découvrir les techniques de l'animation 2D : storyboard, character design, principes du mouvement et réalisation d'un court.",
  schedule: anim?.schedule || "Sessions sur l'année",
  level: anim?.level || 'Débutant à intermédiaire',
};
---
<Base title="À l'année — Formations permanentes | ZIFFA" description="Les formations permanentes du ZIFFA : formation documentaire et formation animation.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; À l'année</div>
      <div class="eyebrow"><span class="arrow">→</span> Formations permanentes</div>
      <h1>Le ZIFFA, <span class="italic yellow">toute l'année</span>.</h1>
      <p>Au-delà du festival, le ZIFFA forme la nouvelle vague de cinéastes de Casamance grâce à deux programmes permanents.</p>
    </div>
  </header>

  <section class="section" id="formations">
    <p class="lead" style="margin-bottom:50px;">Ouvertes aux jeunes de la région, ces formations allient théorie et pratique, encadrées par des professionnels. Candidatures sur dossier via la page <a href="/contact#contact" style="color:var(--red);">Contact</a>.</p>
    <div class="ateliers-grid" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr));">
      <div class="atelier-card" id="formation-doc">
        <span class="atelier-tag">— Programme permanent</span>
        <h3>Formation <span class="italic">documentaire</span></h3>
        <p>{formationDoc.desc}</p>
        <div class="atelier-meta"><span>{formationDoc.schedule}</span><span>{formationDoc.level}</span></div>
      </div>
      <div class="atelier-card" id="formation-anim">
        <span class="atelier-tag">— Programme permanent</span>
        <h3>Formation <span class="italic">animation</span></h3>
        <p>{formationAnim.desc}</p>
        <div class="atelier-meta"><span>{formationAnim.schedule}</span><span>{formationAnim.level}</span></div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="objectifs-section">
    <div class="objectifs-inner">
      <div class="objectifs-header">
        <div class="eyebrow"><span class="arrow">→</span> Comment ça se passe</div>
        <h2 class="section-title">Un <span class="yellow-highlight">parcours</span> complet.</h2>
        <p class="objectifs-tagline">De la candidature à la projection des films réalisés pendant la formation.</p>
      </div>
      <div class="objectifs-grid">
        <div class="objectif-card"><div class="objectif-num">— Étape 01</div><div class="objectif-icon">📝</div><h3>Candidature</h3><p>Dépôt d'un dossier de motivation.</p></div>
        <div class="objectif-card"><div class="objectif-num">— Étape 02</div><div class="objectif-icon">🎥</div><h3>Apprentissage</h3><p>Ateliers théoriques et pratiques encadrés.</p></div>
        <div class="objectif-card"><div class="objectif-num">— Étape 03</div><div class="objectif-icon">✂️</div><h3>Réalisation</h3><p>Production d'un film de fin de formation.</p></div>
        <div class="objectif-card"><div class="objectif-num">— Étape 04</div><div class="objectif-icon">🎬</div><h3>Projection</h3><p>Les meilleurs travaux présentés au public.</p></div>
      </div>
    </div>
  </section>

  <UnderConstruction id="expo-photo" eyebrow="Expo photo" />
</Base>
