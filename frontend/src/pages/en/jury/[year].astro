---
import Base from '../../../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../../../lib/strapi.js';
import PeopleGrid from '../../../components/PeopleGrid.astro';

const { year } = Astro.params;
const res = await fetchAPI('people', { 'filters[type][$eq]': 'jury', 'filters[edition][year][$eq]': year, sort: 'order:asc', populate: 'photo' });
const jury = (res.data || []).map((p) => ({ ini: (p.name || '?').slice(0, 2).toUpperCase(), name: p.name, role: p.role || '', bio: p.bio || '', photo: p.photo?.url ? mediaUrl(p.photo.url) : null, featured: false }));
const editionHref = String(year) === '2025' ? '/en/edition-2025' : `/en/editions/${year}`;
---
<Base title={`The ${year} jury | ZIFFA`} description={`The international jury of the ${year} ZIFFA edition.`}>
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; <a href={editionHref}>{year} edition</a> &nbsp;/&nbsp; Jury</div>
      <div class="eyebrow"><span class="arrow">→</span> The {year} jury</div>
      <h1>The <span class="yellow">jury</span> {year}.</h1>
      <p>The international jury that judged the works in competition.</p>
    </div>
  </header>
  <section class="section">
    {jury.length > 0
      ? <PeopleGrid people={jury} lang="en" />
      : <p class="prog-pdf-empty" style="max-width:480px;margin:0 auto;text-align:center;">The {year} jury will be announced soon.</p>}
    <div style="margin-top:34px;text-align:center;"><a href={`${editionHref}#jury`} class="nav-cta">← Back to the {year} edition</a></div>
  </section>
</Base>
