# Frontend Astro — configuration locale.
# Copie ce fichier en `frontend/.env`.

# --- Mode 100 % LOCAL (recommandé pour développer) ---
# Le site lit le Strapi local (lance "npm run develop" dans cms/).
STRAPI_INTERNAL_URL=http://localhost:1337
PUBLIC_STRAPI_URL=http://localhost:1337

# --- Alternative : lire le Strapi du SERVEUR (prod) ---
# STRAPI_INTERNAL_URL=http://178.105.238.252:1337
# PUBLIC_STRAPI_URL=http://178.105.238.252:1337
