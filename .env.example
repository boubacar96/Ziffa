# ============================================================================
# ZIFFA — variables d'environnement
# Copie ce fichier en `.env` et remplis les valeurs.  NE COMMITE JAMAIS `.env`.
# ============================================================================

# --- Domaines (DNS pointant vers l'IP du VPS) ---
SITE_DOMAIN=ziffa.sn
ADMIN_DOMAIN=admin.ziffa.sn

# --- PostgreSQL ---
DATABASE_NAME=ziffa
DATABASE_USERNAME=ziffa
# Génère un mot de passe fort : openssl rand -base64 24
DATABASE_PASSWORD=CHANGE_ME_strong_password

# --- Secrets Strapi ---
# Génère chaque valeur avec :  openssl rand -base64 32
APP_KEYS=CHANGE_ME_key1,CHANGE_ME_key2,CHANGE_ME_key3,CHANGE_ME_key4
API_TOKEN_SALT=CHANGE_ME
ADMIN_JWT_SECRET=CHANGE_ME
TRANSFER_TOKEN_SALT=CHANGE_ME
JWT_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# --- Frontend Astro ---
# URL publique de Strapi (pour les médias). En général = https://ADMIN_DOMAIN
PUBLIC_STRAPI_URL=https://admin.ziffa.sn

# --- Envoi d'emails (Contact, Newsletter, Inscrire un film -> festival@ziffa.sn) ---
# La boîte festival@ziffa.sn est hébergée chez o2switch (cPanel).
# Important : utiliser le nom RÉEL du serveur (parmesan.o2switch.net) et NON
# webmail.ziffa.sn / mail.ziffa.sn — leur certificat TLS ne correspond pas et
# la validation stricte échoue. Le port 587 (STARTTLS) fonctionne ; le 465 est
# bloqué en sortie sur le VPS.
SMTP_HOST=parmesan.o2switch.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=festival@ziffa.sn
SMTP_PASS=
MAIL_TO=festival@ziffa.sn
MAIL_FROM=ZIFFA <festival@ziffa.sn>

# --- Aperçu (Preview Strapi) : voir les brouillons depuis le Content Manager ---
# 1) Génère un secret partagé :  openssl rand -hex 24
PREVIEW_SECRET=CHANGE_ME
# 2) Dans l'admin Strapi : Paramètres > Jetons d'API > créer un jeton
#    « Lecture seule », puis colle sa valeur ici. Sert au front à lire les
#    brouillons (status=draft). À garder secret.
PREVIEW_API_TOKEN=CHANGE_ME
