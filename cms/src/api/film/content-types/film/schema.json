{
  "kind": "collectionType",
  "collectionName": "films",
  "info": {
    "singularName": "film",
    "pluralName": "films",
    "displayName": "Film"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "fiction",
        "documentaire",
        "animation",
        "court-metrage"
      ]
    },
    "synopsis": {
      "type": "text"
    },
    "director": {
      "type": "string"
    },
    "country": {
      "type": "string"
    },
    "year": {
      "type": "integer"
    },
    "duration": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "poster": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "trailerUrl": {
      "type": "string"
    },
    "edition": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::edition.edition",
      "inversedBy": "films"
    }
  }
}