---
import Base from '../layouts/Base.astro';
import { fetchAPI, mediaUrl, mediaUrls } from '../lib/strapi.js';
import { fallbackMasterclasses } from '../lib/masterclasses.js';
import { FILMS_2025 } from '../lib/films2025.js';

// Vidéo de l'édition 2025 (Vimeo fournie par le client).
const VIDEO_2025 = 'https://player.vimeo.com/video/1169196245?h=5c5f7be273';

// Galerie : photos du CMS, sinon repli sur les photos locales.
const photoRes = await fetchAPI('photos', { populate: 'image', 'pagination[limit]': '12' });
const cmsPhotos = (photoRes.data || []).flatMap((p) => mediaUrls(p.image));
const fallbackPhotos = Array.from({ length: 10 }, (_, i) => `/photos/photo${String(i + 1).padStart(2, '0')}.jpg`);
const photos = [...cmsPhotos, ...fallbackPhotos].slice(0, 8);

// Programme 2025 (dynamique, depuis Strapi).
const daysRes = await fetchAPI('programme-days', { 'filters[edition][year][$eq]': '2025', sort: 'order:asc', populate: 'activities', 'pagination[limit]': '20' });
const days = daysRes.data || [];

// Palmarès 2025 (Strapi `prize`) avec repli.
const prizeRes = await fetchAPI('prizes', { 'filters[edition][year][$eq]': '2025', populate: 'image', 'pagination[limit]': '20' });
const cmsPrizes = (prizeRes.data || []).map((p) => ({ name: p.name, winner: p.winner || '', image: p.image?.url ? mediaUrl(p.image.url) : null }));
const fallbackPrizes = [
  { name: 'Meilleur long métrage de fiction de la sous-région', winner: '', image: null },
  { name: 'Meilleur long métrage international de fiction', winner: '', image: null },
  { name: 'Prix New Génération — West Africa', winner: '', image: null },
  { name: 'Prix New Génération — International', winner: '', image: null },
  { name: 'Prix du public', winner: '', image: null },
];
const prizes = cmsPrizes.length ? cmsPrizes : fallbackPrizes;

// Jury 2025 (Strapi `person` type=jury) avec repli.
const juryRes = await fetchAPI('people', { 'filters[type][$eq]': 'jury', 'filters[edition][year][$eq]': '2025', sort: 'order:asc', populate: 'photo' });
const cmsJury = (juryRes.data || []).map((j) => ({ ini: (j.name || '?').slice(0, 2).toUpperCase(), name: j.name, role: j.role || '', bio: j.bio || '', photo: j.photo?.url ? mediaUrl(j.photo.url) : null }));
const fallbackJury = [
  { ini: 'P', name: 'Président·e du jury 2025', role: 'Présidence', bio: 'À annoncer.', photo: null },
  { ini: 'J2', name: 'Membre du jury', role: 'Réalisation', bio: 'À annoncer.', photo: null },
  { ini: 'J3', name: 'Membre du jury', role: 'Production', bio: 'À annoncer.', photo: null },
];
const jury = cmsJury.length ? cmsJury : fallbackJury;

// Masterclasses 2025 (depuis le programme, type=masterclass) avec repli.
const mcRes = await fetchAPI('masterclasses', { 'filters[edition][year][$eq]': '2025', populate: 'cover', sort: 'order:asc', 'pagination[limit]': '20' });
const cmsMc = (mcRes.data || []).map((m) => ({ slug: m.slug, title: m.title, excerpt: m.excerpt || '', cover: m.cover?.url ? mediaUrl(m.cover.url) : null }));
const masterclasses = cmsMc.length ? cmsMc.filter((m) => m.slug) : fallbackMasterclasses('fr');

// Films de la sélection 2025 (depuis le programme) avec repli.
const filmRes = await fetchAPI('programme-events', { 'filters[edition][year][$eq]': '2025', populate: 'films', 'pagination[limit]': '100' });
const cmsFilms = (filmRes.data || []).flatMap((m) => m.films || []).map((f) => ({ title: f.title, director: f.director || '', country: f.country || '', year: f.year || '', duration: f.duration || '' }));
const films2025 = cmsFilms.length ? cmsFilms : FILMS_2025;

// Rétrospective « en chiffres » (à ajuster avec les vrais chiffres).
const edStats = [
  { n: 4, suffix: 'j', label: 'de festival' },
  { n: 25, suffix: '', label: 'films projetés' },
  { n: 10, suffix: '+', label: 'pays représentés' },
  { n: 1000, suffix: '+', label: 'spectateurs' },
];
const highlights = [
  { img: photos[1] || '/photos/photo02.jpg', title: "Soirée d'ouverture", desc: 'Cérémonie, spectacles et premières projections.' },
  { img: photos[4] || '/photos/photo05.jpg', title: 'Films en compétition', desc: 'Courts métrages internationaux et longs métrages.' },
  { img: photos[6] || '/photos/photo07.jpg', title: 'Femmes en lumière', desc: 'Rencontres avec cinéastes et créatrices.' },
  { img: photos[2] || '/photos/photo03.jpg', title: 'Cérémonie de clôture', desc: 'Palmarès et projection des films primés.' },
];
---
<Base title="Édition 2025 — Retour en images | ZIFFA" description="Revivez la première édition du ZIFFA (2025) : vidéo, galerie, palmarès, programme et jury.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; Édition 2025</div>
      <div class="eyebrow"><span class="arrow">→</span> Édition passée · N°01</div>
      <h1>Retour sur <span class="yellow">2025</span>.</h1>
      <p>La première édition du ZIFFA a réuni public et professionnels autour du cinéma africain.</p>
    </div>
  </header>

  <!-- L'ÉDITION EN CHIFFRES -->
  <section class="section" id="chiffres">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> L'édition en chiffres</div><h2 class="section-title">2025 en <span class="red">chiffres</span>.</h2></div></div>
    <div class="edstat-band">
      {edStats.map((s) => (
        <div class="edstat">
          <div class="edstat-num" data-count={String(s.n)}><span class="edstat-val">{s.n}</span>{s.suffix && <span class="edstat-suffix">{s.suffix}</span>}</div>
          <div class="edstat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- EN IMAGES : vidéo (teaser cinéma, clic pour lire) -->
  <section class="teaser-section" id="images">
    <div class="teaser-inner">
      <div class="teaser-head">
        <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Le film de l'édition 2025</div>
        <h2 class="section-title">L'édition <span class="red">2025</span> en <span class="italic">images</span>.</h2>
        <p>Les temps forts de notre première édition : projections, masterclasses et rencontres.</p>
      </div>
      <div class="teaser-player" id="teaser-player" data-embed={VIDEO_2025} role="button" tabindex="0" aria-label="Lire le film de l'édition 2025">
        <div class="teaser-poster"><span class="teaser-mark">ZIFFA · 2025</span></div>
        <div class="teaser-play"><span>▶</span></div>
        <div class="teaser-cta">Regarder le film de l'édition</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> La galerie</div><h2 class="section-title">Souvenirs de <span class="italic">2025</span>.</h2></div><a href="/galerie/2025" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Voir toute la galerie →</a></div>
    <div class="gallery-marquee">
      <div class="gallery-marquee-track">
        {photos.map((src) => (<figure><img src={src} alt="ZIFFA 2025" loading="lazy" /></figure>))}
        {photos.map((src) => (<figure aria-hidden="true"><img src={src} alt="" loading="lazy" /></figure>))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- TEMPS FORTS -->
  <section class="section" id="temps-forts">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Moments marquants</div><h2 class="section-title">Les <span class="red">temps forts</span>.</h2></div></div>
    <div class="highlights-editorial">
      {highlights.map((h, i) => (
        <article class="hl-row">
          <div class="hl-img" style={`background-image:url('${h.img}')`}></div>
          <div class="hl-text"><span class="hl-num">— {String(i + 1).padStart(2, '0')}</span><h3>{h.title}</h3><p>{h.desc}</p></div>
        </article>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- SÉLECTION 2025 -->
  <section class="section" id="selection">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Sélection officielle</div><h2 class="section-title">Les <span class="red">films</span> 2025.</h2></div></div>
    <div class="films-selection">
      {films2025.map((f) => (
        <article class="film-sel-card">
          <h3>{f.title}</h3>
          {f.director && <div class="film-sel-dir">{f.director}</div>}
          <div class="film-sel-meta">{[f.country, f.year, f.duration].filter(Boolean).join(' · ')}</div>
        </article>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- PRIX ET DISTINCTIONS -->
  <section class="section" id="prix">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Palmarès</div><h2 class="section-title">Prix &amp; <span class="red">distinctions</span>.</h2></div></div>
    <p class="lead" style="max-width:760px;margin-bottom:30px;">Des prix seront remis dans chaque catégorie (régionale et internationale) :</p>
    <div class="prize-grid">
      {prizes.map((p, i) => (
        p.image ? (
          <div class="prize-photo" style={`background-image:linear-gradient(to top, rgba(15,58,32,.94) 0%, rgba(15,58,32,.15) 55%, rgba(15,58,32,0) 100%), url('${p.image}')`}>
            <div class="prize-photo-body"><h3>{p.name}</h3>{p.winner && <div class="winner">{p.winner}</div>}</div>
          </div>
        ) : (
          <div class={`prize-card prize-card--accent oc-${['red', 'green', 'yellow', 'orange'][i % 4]}`}><h3>{p.name}</h3><div class="winner">{p.winner || 'Lauréat·e à annoncer'}</div></div>
        )
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- PROGRAMME 2025 (Strapi — cartes par jour) -->
  <section class="programme-section" id="programme">
    <div class="programme-inner">
      <div style="text-align:center;margin-bottom:10px;"><div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Ce qu'il s'est passé</div><h2 class="section-title" style="margin:12px auto;text-align:center;">Le <span class="italic">programme</span> 2025.</h2></div>
      {days.length > 0 ? (
        <>
          <div class="prog-days-grid">
            {days.map((d, i) => (
              <a class="prog-day-card" href={`/programme/${d.slug}`}>
                <span class="pd-num">— Jour {String(i + 1).padStart(2, '0')}</span>
                <span class="pd-label">{d.label}</span>
                {d.subtitle && <span class="pd-sub">{d.subtitle}</span>}
                <span class="pd-count">{(d.activities?.length || 0)} activités</span>
                <span class="pd-go">Voir le détail →</span>
              </a>
            ))}
          </div>
          <div class="prog-complete-btn">
            <a href="/programme-complet/2025" class="nav-cta">Voir le programme complet ↗</a>
          </div>
        </>
      ) : (
        <p class="prog-pdf-empty" style="max-width:520px;margin:0 auto;">Le programme de l'édition 2025 sera bientôt disponible.</p>
      )}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- JURY 2025 -->
  <section class="section" id="jury">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Le jury 2025</div><h2 class="section-title">Le <span class="italic">jury</span>.</h2></div></div>
    <div class="team-grid">
      {jury.map((j) => (
        <button type="button" class="team-portrait js-person" data-name={j.name} data-role={j.role} data-bio={j.bio} data-photo={j.photo || ''} data-ini={j.ini}>
          <div class="team-photo" style={j.photo ? `background-image:url('${j.photo}')` : ''}>{j.photo ? '' : <span class="team-ini">{j.ini}</span>}</div>
          <div class="team-info"><div class="team-name">{j.name}</div><div class="team-role">{j.role}</div></div>
        </button>
      ))}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- MASTERCLASSES 2025 -->
  <section class="section" id="masterclasses">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Transmission 2025</div><h2 class="section-title">Master-<span class="italic">classes</span>.</h2></div></div>
    <div class="formations-grid">
      {masterclasses.map((m) => (
        <a class="formation-card" href={`/masterclasses/${m.slug}`}>
          <div class="formation-cover" style={m.cover ? `background-image:url('${m.cover}')` : ''}></div>
          <div class="formation-body"><h3>{m.title}</h3>{m.excerpt && <p>{m.excerpt}</p>}<span class="formation-more">Lire la suite →</span></div>
        </a>
      ))}
    </div>
  </section>

  <!-- Popup profil jury -->
  <div class="person-modal" id="person-modal" hidden>
    <div class="pm-backdrop" data-close></div>
    <div class="pm-dialog" role="dialog" aria-modal="true" aria-labelledby="pm-name">
      <button class="pm-close" data-close aria-label="Fermer">×</button>
      <div class="pm-photo" id="pm-photo"></div>
      <div class="pm-body">
        <div class="pm-role" id="pm-role"></div>
        <h3 id="pm-name"></h3>
        <p id="pm-bio"></p>
      </div>
    </div>
  </div>
</Base>

<script>
  const tp = document.getElementById('teaser-player');
  if (tp) {
    const play = () => {
      if (tp.classList.contains('playing')) return;
      const base = tp.dataset.embed;
      const src = base + (base.includes('?') ? '&' : '?') + 'autoplay=1';
      tp.innerHTML = '<iframe src="' + src + '" title="ZIFFA 2025 — le film du festival" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="width:100%;height:100%;border:0;display:block;"></iframe>';
      tp.classList.add('playing');
    };
    tp.addEventListener('click', play);
    tp.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); play(); } });
  }

  // Compteurs animés « en chiffres »
  const band = document.querySelector('.edstat-band');
  if (band) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const run = () => {
      band.querySelectorAll('.edstat-num').forEach((el) => {
        const val = el.querySelector('.edstat-val');
        const target = parseInt(el.dataset.count, 10) || 0;
        if (reduce) { val.textContent = String(target); return; }
        const dur = 1200; const t0 = performance.now();
        val.textContent = '0';
        const step = (now) => {
          const p = Math.min(1, (now - t0) / dur);
          val.textContent = String(Math.round((1 - Math.pow(1 - p, 3)) * target));
          if (p < 1) requestAnimationFrame(step);
        };
        requestAnimationFrame(step);
      });
    };
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((es) => { es.forEach((e) => { if (e.isIntersecting) { run(); io.disconnect(); } }); }, { threshold: 0.4 });
      io.observe(band);
    } else { run(); }
  }

  // Popup profil jury
  const modal = document.getElementById('person-modal');
  if (modal) {
    const pmPhoto = document.getElementById('pm-photo');
    const pmName = document.getElementById('pm-name');
    const pmRole = document.getElementById('pm-role');
    const pmBio = document.getElementById('pm-bio');
    const pmClose = modal.querySelector('.pm-close');
    let pmLast = null;
    const open = (d) => {
      pmName.textContent = d.name || '';
      pmRole.textContent = d.role || '';
      pmBio.textContent = d.bio || '';
      if (d.photo) { pmPhoto.style.backgroundImage = `url('${d.photo}')`; pmPhoto.textContent = ''; pmPhoto.classList.remove('pm-photo--ini'); }
      else { pmPhoto.style.backgroundImage = ''; pmPhoto.textContent = d.ini || ''; pmPhoto.classList.add('pm-photo--ini'); }
      modal.hidden = false; document.body.style.overflow = 'hidden';
      pmLast = document.activeElement; pmClose.focus();
    };
    const close = () => { modal.hidden = true; document.body.style.overflow = ''; if (pmLast && pmLast.focus) pmLast.focus(); };
    document.querySelectorAll('.js-person').forEach((c) => c.addEventListener('click', () => open(c.dataset)));
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (modal.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'Tab') { e.preventDefault(); pmClose.focus(); }
    });
  }
</script>
