# Strapi en LOCAL (npm run develop) — base SQLite, aucun service externe.
# Copie ce fichier en `cms/.env` puis lance `npm run develop`.
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# Base locale SQLite (un simple fichier dans cms/.tmp/)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Secrets LOCAUX uniquement (sans importance, ne PAS réutiliser en prod)
APP_KEYS=local1,local2,local3,local4
API_TOKEN_SALT=localApiSalt
ADMIN_JWT_SECRET=localAdminSecret
TRANSFER_TOKEN_SALT=localTransferSalt
JWT_SECRET=localJwtSecret
ENCRYPTION_KEY=localEncryptionKeyChangeMe
