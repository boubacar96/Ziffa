---
import Base from '../../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../../lib/strapi.js';

const PROG_YEAR = 2027;

const edRes = await fetchAPI('editions', { 'filters[isCurrent][$eq]': 'true', populate: 'poster', 'pagination[limit]': '1' });
const edition = (edRes.data || [])[0] || null;
const poster = edition?.poster?.url ? mediaUrl(edition.poster.url) : null;

const daysRes = await fetchAPI('programme-days', { 'filters[edition][year][$eq]': String(PROG_YEAR), sort: 'order:asc', populate: 'activities', 'pagination[limit]': '20' });
const days = daysRes.data || [];

const prizes = [
  { icon: '🏆', name: 'ZIFFA Grand Prize', desc: 'The festival’s highest distinction.' },
  { icon: '🎬', name: 'Fiction Award', desc: 'Best fiction film of the selection.' },
  { icon: '🎞️', name: 'Documentary Award', desc: 'Best documentary vision.' },
  { icon: '✨', name: 'Animation Award', desc: 'Best animated work.' },
  { icon: '⏱️', name: 'Short Film Award', desc: 'Best short work.' },
  { icon: '❤️', name: 'Audience Award', desc: 'Awarded by audience votes.' },
];
const jury = [
  { ini: 'P', name: 'Jury president', role: 'TBA' },
  { ini: 'J2', name: 'Jury member', role: 'Directing' },
  { ini: 'J3', name: 'Jury member', role: 'Production' },
  { ini: 'J4', name: 'Jury member', role: 'Press & critics' },
];
---
<Base title="2027 Edition — Programme, awards & jury | ZIFFA" description="ZIFFA 2027 edition — awards, programme, jury, masterclasses and poster.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; 2027 Edition</div>
      <div class="eyebrow"><span class="arrow">→</span> Next edition · 17–20 Nov 2027</div>
      <h1><span class="yellow">2027</span>, edition <span class="italic">No.03</span>.</h1>
      <p>Four days of screenings, encounters and training in Ziguinchor.</p>
    </div>
  </header>

  <section class="section" id="prix">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Official competition</div><h2 class="section-title">The 2027 <span class="red">awards</span>.</h2></div></div>
    <div class="prize-grid">
      {prizes.map((p) => (<div class="prize-card"><div class="trophy">{p.icon}</div><h3>{p.name}</h3><p>{p.desc}</p></div>))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="programme-section" id="programme">
    <div class="programme-inner">
      <div style="text-align:center;margin-bottom:10px;"><div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Official programme</div><h2 class="section-title" style="margin:12px auto;text-align:center;">The <span class="red">programme</span>.</h2></div>
      {days.length > 0 ? (
        <>
          <div class="prog-days-grid">
            {days.map((d, i) => (
              <a class="prog-day-card" href={`/en/programme/${d.slug}`}>
                <span class="pd-num">— Day {String(i + 1).padStart(2, '0')}</span>
                <span class="pd-label">{d.label}</span>
                {d.subtitle && <span class="pd-sub">{d.subtitle}</span>}
                <span class="pd-count">{(d.activities?.length || 0)} activities</span>
                <span class="pd-go">See details →</span>
              </a>
            ))}
          </div>
          <div class="prog-complete-btn">
            <a href={`/en/programme-complet/${PROG_YEAR}`} class="nav-cta">View the full programme ↗</a>
          </div>
        </>
      ) : (
        <p class="prog-pdf-empty" style="max-width:520px;margin:0 auto;">The detailed programme will be available soon. Check back!</p>
      )}
    </div>
  </section>

  <section class="section" id="jury">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> The 2027 jury</div><h2 class="section-title">An international <span class="italic">jury</span>.</h2></div></div>
    <div class="people-grid">
      {jury.map((j) => (<div class="person-card"><div class="person-avatar">{j.ini}</div><div class="person-name">{j.name}</div><div class="person-role">{j.role}</div></div>))}
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="masterclasses">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Knowledge sharing</div><h2 class="section-title">Master-<span class="italic">classes</span>.</h2></div><a href="/en/participer#accreditation" class="btn-ghost">Get accredited →</a></div>
    <div class="ateliers-grid">
      <div class="atelier-card"><span class="atelier-tag">— Masterclass</span><h3>Documentary <span class="italic">directing</span></h3><p>Building a strong documentary narrative, with a guest director.</p><div class="atelier-meta"><span>Sat 20 Nov</span><span>All levels</span></div></div>
      <div class="atelier-card"><span class="atelier-tag">— Masterclass</span><h3>Screen<span class="italic">writing</span></h3><p>From synopsis to treatment for fiction and short film.</p><div class="atelier-meta"><span>Fri 19 Nov</span><span>Beginner</span></div></div>
      <div class="atelier-card"><span class="atelier-tag">— Practical workshop</span><h3>2D <span class="italic">animation</span></h3><p>Animation techniques and making animated short films.</p><div class="atelier-meta"><span>Sat 20 Nov</span><span>Intermediate</span></div></div>
    </div>
  </section>

  <section class="objectifs-section" id="affiche">
    <div class="objectifs-inner">
      <div class="affiche-wrap">
        <div class="affiche-poster">{poster ? <img src={poster} alt="ZIFFA 2027 poster" /> : <span class="placeholder">ZIFFA<br />2027</span>}</div>
        <div>
          <div class="eyebrow"><span class="arrow">→</span> Visual identity</div>
          <h2 class="section-title" style="color:var(--bg);">The <span class="yellow-highlight">poster</span>.</h2>
          <p class="objectifs-tagline" style="margin:16px 0 28px;">The official 2027 poster will be unveiled soon.</p>
          <a href="/en/contact#newsletter" class="nav-cta" style="background:var(--yellow);color:var(--green-deep);">Get notified ↗</a>
        </div>
      </div>
    </div>
  </section>
</Base>
