---
import Base from '../../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../../lib/strapi.js';

const teamRes = await fetchAPI('people', { 'filters[type][$eq]': 'equipe', sort: 'order:asc', populate: 'photo' });
const cmsTeam = teamRes.data || [];
// Local fallback photos (used only when no photo is set in Strapi).
const LOCAL_TEAM_PHOTOS = { 'Babacar Ba': '/team/babacar-ba.jpg' };
const mapPerson = (p) => ({ ini: (p.name || '?').slice(0, 2).toUpperCase(), name: p.name, role: p.role || '', bio: p.bio || '', photo: p.photo?.url ? mediaUrl(p.photo.url) : (LOCAL_TEAM_PHOTOS[p.name] || null), featured: !!p.featured });
const fallbackTeam = [
  { ini: 'BB', name: 'Babacar Ba', role: 'Festival President', bio: 'Audiovisual producer, director and photographer, a graduate of the Agnès Varda film school (Brussels). Founder of ZIFFA, he has worked for some twenty years to nurture Senegalese film talent and make Ziguinchor a crossroads for African cinema.', photo: null, featured: true },
  { ini: 'YP', name: 'Yves-François Preira', role: 'President of FOTTI Cultures', bio: 'President of the FOTTI Cultures association, which runs the festival.', photo: null, featured: false },
  { ini: 'OS', name: 'Oumou Sy', role: 'Honorary President', bio: 'Internationally renowned stylist and set designer, an emblematic figure of African creation.', photo: null, featured: false },
  { ini: 'SB', name: 'Selly Ba', role: 'Sponsors & partnerships', bio: '', photo: null, featured: false },
];
const team = cmsTeam.length ? cmsTeam.map(mapPerson) : fallbackTeam;

const partRes = await fetchAPI('partners', { populate: 'logo', sort: 'order:asc' });
const fallbackPartners = [
  { name: 'Wallonie-Bruxelles Int.', url: 'https://www.wbi.be', logo: '/partenaires/wallonie-bruxelles.jpg' },
  { name: 'Alliance Française', url: '#', logo: '/partenaires/alliance-francaise.jpg' },
  { name: 'Air Sénégal', url: 'https://flyairsenegal.com', logo: '/partenaires/air-senegal.jpg' },
  { name: 'FOTTI', url: '#', logo: '/partenaires/fotti.jpg' },
  { name: 'LONASE', url: 'https://www.lonase.sn', logo: '/partenaires/lonase.jpg' },
  { name: 'TALAATA Production', url: '#', logo: '/partenaires/talaata.jpg' },
];
const cmsPartnersMapped = (partRes.data || []).map((p) => ({ name: p.name, url: p.url || '#', logo: p.logo?.url ? mediaUrl(p.logo.url) : null }));
// Strapi only as soon as there is at least 1 partner; otherwise demo logos.
const partners = cmsPartnersMapped.length ? cmsPartnersMapped : fallbackPartners;

const objectifs = [
  { num: '— 01', icon: '🎬', title: 'Promoting African cinema', desc: 'Spotlight the continent’s talents and stories, and make African cinema desirable to a wide audience: youth, families, students.' },
  { num: '— 02', icon: '🎥', title: 'Boosting Casamance’s film potential', desc: 'Encourage national and international shoots and offer cinema in and for the city of Ziguinchor.' },
  { num: '— 03', icon: '🎓', title: 'Training young professionals', desc: 'Strengthen the training and employment of local talent, in the continuity of FOTTI Cultures’ Film Academy.' },
  { num: '— 04', icon: '🌍', title: 'Stimulating the local economy through cultural tourism', desc: 'Support the Casamance economy and promote the “Casamance” brand as a lever of soft power and tourism development.' },
];
---
<Base title="The ZIFFA — Overview, goals & team" description="Official overview of ZIFFA: its goals, team, press, partners and archives.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; The ZIFFA</div>
      <div class="eyebrow"><span class="arrow">→</span> Discover the festival</div>
      <h1>The <span class="yellow">ZIFFA</span>.</h1>
      <p>The Ziguinchor International Film Festival &amp; Animation celebrates African cinema in Casamance.</p>
    </div>
  </header>

  <section class="section" id="histoire">
    <div class="section-head">
      <div><div class="eyebrow"><span class="arrow">→</span> Festival overview</div><h2 class="section-title">About the<br /><span class="red">festival</span>.</h2></div>
    </div>
    <div class="presentation-editorial" style="max-width:880px;">
      <p>ZIFFA was born from a simple observation: of the dozen-plus film festivals in Senegal, most take place in Dakar and <strong>none in Casamance</strong>. Launched in <strong>November 2025 in Ziguinchor</strong>, it shines a light on the region through a <strong>pan-African and international</strong> programme, and celebrates youth creativity and the potential of southern Senegal.</p>
      <p>The festival extends the work of the <strong>FOTTI Cultures</strong> association, whose DNA has been film training for nearly ten years. From 2020 to 2024, its Film Academy trained <strong>120 young people from 10 regions</strong> of Senegal (96 hours of training across Ziguinchor, Saint-Louis, Dakar, Lac Rose and Toubacouta).</p>
      <p>Each edition combines screenings, masterclasses and <strong>training residencies</strong>, with a youth strand (animation workshops, children's screenings). Twelve days of intensive workshops, open to professionals and young people alike, precede the festival.</p>
    </div>
  </section>

  <section class="objectifs-section" id="valeurs">
    <div class="objectifs-inner">
      <div class="objectifs-header">
        <div class="eyebrow"><span class="arrow">→</span> Our mission</div>
        <h2 class="section-title">Festival <span class="yellow-highlight">goals</span>.</h2>
        <p class="objectifs-tagline">Promote African cinema and develop the film industry in Casamance.</p>
      </div>
      <div class="objectifs-grid">
        {objectifs.map((o, i) => (
          <div class={`objectif-card objectif-card--filled oc-${['red', 'green', 'yellow', 'orange'][i % 4]}`}><div class="objectif-num">{o.num}</div><h3>{o.title}</h3><p>{o.desc}</p></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="equipe">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> The people behind the festival</div><h2 class="section-title">The <span class="italic">team</span>.</h2></div></div>

    <div class="fw-scroller">
      <button type="button" class="fw-arrow fw-prev" aria-label="Previous">‹</button>
      <div class="team-grid team-grid--row" data-rail>
        {team.map((m) => (
          <button type="button" class={`team-portrait js-person ${m.featured ? 'team-portrait--focus' : ''}`} data-name={m.name} data-role={m.role} data-bio={m.bio} data-photo={m.photo || ''} data-ini={m.ini}>
            <div class="team-photo" style={m.photo ? `background-image:url('${m.photo}')` : ''}>{m.photo ? '' : <span class="team-ini">{m.ini}</span>}{m.featured && <span class="team-badge">★ Founder</span>}</div>
            <div class="team-info"><div class="team-name">{m.name}</div><div class="team-role">{m.role}</div></div>
          </button>
        ))}
      </div>
      <button type="button" class="fw-arrow fw-next" aria-label="Next">›</button>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="presse">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Press area</div><h2 class="section-title">Press <span class="red">kit</span>.</h2></div><a href="/en/presse" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">Go to the press area →</a></div>
    <p class="lead" style="max-width:760px;margin-bottom:30px;">All ZIFFA press resources, to download one by one, by selection or in a batch.</p>
    <div class="presse-cards">
      <a class="presse-card pc-red" href="/en/presse/dossier"><span class="presse-ic">📄</span><h3>Press kit</h3><p>Overview, key figures and contacts.</p><span class="presse-go">Open →</span></a>
      <a class="presse-card pc-green" href="/en/presse/logos"><span class="presse-ic">🎨</span><h3>Logos & brand</h3><p>Logos (colour, white) and usage rules.</p><span class="presse-go">Open →</span></a>
      <a class="presse-card pc-yellow" href="/en/presse/photos"><span class="presse-ic">📸</span><h3>Photo library</h3><p>High-resolution photos for the press.</p><span class="presse-go">Open →</span></a>
    </div>
  </section>

  <section class="partners-section" id="partenaires">
    <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Supporters & Partners</div>
    <h2 class="section-title" style="margin:16px auto 0;max-width:700px;">They <span class="red">support</span><br />ZIFFA.</h2>
    <p class="partners-intro">The festival is made possible thanks to committed institutions and partners.</p>
    <div class="partners-marquee">
      <div class="partners-marquee-track">
        {partners.map((p) => (
          <a href={p.url} target="_blank" rel="noopener" class="partner-logo" title={p.name}>{p.logo && <img src={p.logo} alt={p.name} />}<span class="partner-logo-name">{p.name}</span></a>
        ))}
        {partners.map((p) => (
          <a href={p.url} target="_blank" rel="noopener" class="partner-logo" aria-hidden="true" tabindex="-1">{p.logo && <img src={p.logo} alt="" />}<span class="partner-logo-name">{p.name}</span></a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="archives">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Festival memory</div><h2 class="section-title">The <span class="italic">archives</span>.</h2></div></div>
    <div class="archive-cards">
      <a class="archive-card" href="/en/edition-2025">
        <div class="archive-head archive-head--past"><span class="archive-num">— Edition 01</span><span class="archive-year">2025</span></div>
        <div class="archive-body"><p>Pictures, prize list and programme of the first edition.</p><span class="archive-link">Relive 2025 ↗</span></div>
      </a>
      <a class="archive-card" href="/en/editions/2027">
        <div class="archive-head archive-head--next"><span class="archive-num">— Next edition</span><span class="archive-year">2027</span></div>
        <div class="archive-body"><p>Programme, juries, awards and masterclasses to come.</p><span class="archive-link">Discover 2027 ↗</span></div>
      </a>
    </div>
  </section>

  <div class="person-modal" id="person-modal" hidden>
    <div class="pm-backdrop" data-close></div>
    <div class="pm-dialog" role="dialog" aria-modal="true" aria-labelledby="pm-name">
      <button class="pm-close" data-close aria-label="Close">×</button>
      <div class="pm-photo" id="pm-photo"></div>
      <div class="pm-body">
        <div class="pm-role" id="pm-role"></div>
        <h3 id="pm-name"></h3>
        <p id="pm-bio"></p>
      </div>
    </div>
  </div>
</Base>

<script>
  const modal = document.getElementById('person-modal');
  if (modal) {
    const pmPhoto = document.getElementById('pm-photo');
    const pmName = document.getElementById('pm-name');
    const pmRole = document.getElementById('pm-role');
    const pmBio = document.getElementById('pm-bio');
    const pmClose = modal.querySelector('.pm-close');
    let pmLast = null;
    const open = (d) => {
      pmName.textContent = d.name || '';
      pmRole.textContent = d.role || '';
      pmBio.textContent = d.bio || '';
      if (d.photo) { pmPhoto.style.backgroundImage = `url('${d.photo}')`; pmPhoto.textContent = ''; pmPhoto.classList.remove('pm-photo--ini'); }
      else { pmPhoto.style.backgroundImage = ''; pmPhoto.textContent = d.ini || ''; pmPhoto.classList.add('pm-photo--ini'); }
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      pmLast = document.activeElement;
      pmClose.focus();
    };
    const close = () => { modal.hidden = true; document.body.style.overflow = ''; if (pmLast && pmLast.focus) pmLast.focus(); };
    document.querySelectorAll('.js-person').forEach((c) => c.addEventListener('click', () => open(c.dataset)));
    modal.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (modal.hidden) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'Tab') { e.preventDefault(); pmClose.focus(); }
    });
  }
</script>
