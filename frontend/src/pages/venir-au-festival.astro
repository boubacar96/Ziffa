---
import Base from '../layouts/Base.astro';

const venues = [
  { n: 1, name: 'Mémorial du bateau le Joola', role: 'Cérémonies & hommages', icon: '🕯️', hex: '#D63832', lat: 12.5688, lng: -16.2742 },
  { n: 2, name: 'Centre Culturel Régional', role: 'Projections & rencontres', icon: '🏛️', hex: '#2A6B3F', lat: 12.5656892, lng: -16.2673909 },
  { n: 3, name: 'U.F.R Santé — Université Assane Seck', role: 'QG du festival', icon: '🎓', hex: '#F2B718', lat: 12.5494994, lng: -16.2830714 },
  { n: 4, name: 'Place Bambaya', role: 'Projection plein air', icon: '🎪', hex: '#2A6B3F', lat: 12.5746631, lng: -16.2850057 },
];

const travel = [
  { color: 'red', icon: '✈️', title: 'En avion', text: "Vols <strong>Dakar → Ziguinchor</strong> (≈ 1 h) avec Air Sénégal. L'aéroport est à 10 min du centre-ville." },
  { color: 'green', icon: '🚗', title: 'En route', text: "≈ 450 km depuis Dakar (≈ 7–8 h) via la Transgambienne. Bus, « sept-places » et locations relient les deux villes." },
  { color: 'yellow', icon: '⛴️', title: 'En bateau', text: "Le ferry <strong>Aline Sitoé Diatta</strong> relie Dakar à Ziguinchor (≈ 15 h) — une traversée emblématique à vivre au moins une fois." },
];

const infos = [
  { icon: '🌤️', title: 'Climat', text: 'Novembre : chaud et ensoleillé. Prévoyez des tenues légères.' },
  { icon: '💶', title: 'Monnaie', text: 'Franc CFA (FCFA). Espèces conseillées ; distributeurs en ville.' },
  { icon: '🗣️', title: 'Langues', text: 'Français, wolof et diola. Accueil chaleureux et convivial.' },
  { icon: '🎟️', title: 'Accès', text: 'Projections en accès libre dans la limite des places. Accréditation pros via la page Contact.' },
];
---
<Base title="Venir au festival | ZIFFA" description="Venir au ZIFFA à Ziguinchor : dates, lieux, comment venir (avion, route, bateau) et infos pratiques.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; Participer &nbsp;/&nbsp; Venir au festival</div>
      <div class="eyebrow"><span class="arrow">→</span> Infos pratiques</div>
      <h1>Venir au <span class="yellow">festival</span>.</h1>
      <p>Tout pour préparer votre venue à Ziguinchor, au cœur de la Casamance.</p>
    </div>
  </header>

  <section class="section" id="lieux">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Quand &amp; où</div><h2 class="section-title">Les <span class="red">lieux</span>.</h2></div></div>
    <p class="lead" style="max-width:760px;margin-bottom:24px;">Le festival se déploie sur plusieurs sites à Ziguinchor. Cliquez sur un lieu pour le situer sur la carte :</p>
    <div class="zmap">
      <div class="zmap-canvas">
        <div id="ziffa-map" role="application" aria-label="Carte des lieux du festival à Ziguinchor"></div>
        <button id="zmap-reset" class="zmap-reset" type="button">⤢ Vue d'ensemble</button>
      </div>
      <div class="zmap-aside">
        {venues.map((v) => (
          <button class="zmap-card" data-i={v.n - 1} style={`--vc:${v.hex}`} type="button">
            <span class="zmap-num">{v.n}</span>
            <span class="zmap-ic">{v.icon}</span>
            <span class="zmap-txt"><strong>{v.name}</strong><em>{v.role}</em></span>
            <span class="zmap-go">→</span>
          </button>
        ))}
        <p class="zmap-hint">Astuce : cliquez sur un marqueur pour l'itinéraire Google Maps.</p>
      </div>
    </div>
  </section>

  <section class="section" id="comment-venir">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Comment venir</div><h2 class="section-title">Y <span class="red">arriver</span>.</h2></div></div>
    <div class="presse-cards">
      {travel.map((m) => (
        <div class={`presse-card pc-${m.color}`}>
          <span class="presse-ic">{m.icon}</span>
          <h3>{m.title}</h3>
          <p set:html={m.text}></p>
        </div>
      ))}
    </div>
  </section>

  <section class="section" id="sejour">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Sur place</div><h2 class="section-title">Votre <span class="red">séjour</span>.</h2></div></div>
    <div class="presentation-editorial" style="max-width:820px;">
      <p><strong>Où dormir ?</strong> Ziguinchor offre hôtels, auberges et maisons d'hôtes, du centre-ville aux rives du fleuve Casamance. Pensez à <strong>réserver tôt</strong> pendant le festival.</p>
      <p><strong>Se déplacer.</strong> Les sites du centre (Mémorial du Joola, Centre Culturel Régional, Place Bambaya) sont à ~5 min à pied les uns des autres ; l'Université Assane Seck (U.F.R Santé) est à ~10 min en minibus. Taxis et moto-taxis (« Jakarta ») complètent les trajets.</p>
      <p><strong>Ambiance.</strong> Entre les projections, profitez de la gastronomie casamançaise, des marchés et de la chaleur de l'accueil ziguinchorois.</p>
    </div>
  </section>

  <section class="section" id="infos">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Bon à savoir</div><h2 class="section-title">Infos <span class="red">pratiques</span>.</h2></div></div>
    <div class="presse-cards">
      {infos.map((m) => (
        <div class="presse-card pc-green">
          <span class="presse-ic">{m.icon}</span>
          <h3>{m.title}</h3>
          <p>{m.text}</p>
        </div>
      ))}
    </div>
    <div style="margin-top:34px;"><a href="/contact#contact" class="nav-cta">Une question ? Contactez-nous ↗</a></div>
  </section>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
  <script is:inline define:vars={{ venues }}>
    (function () {
      if (!window.L) return;
      const el = document.getElementById('ziffa-map');
      if (!el) return;
      const map = L.map(el, { scrollWheelZoom: false, zoomControl: true });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        maxZoom: 19, subdomains: 'abcd', attribution: '&copy; OpenStreetMap, &copy; CARTO',
      }).addTo(map);

      const markers = [], pts = [];
      const dirUrl = (name) => 'https://www.google.com/maps/dir/?api=1&destination=' + encodeURIComponent(name + ' Ziguinchor');

      venues.forEach(function (v, i) {
        const icon = L.divIcon({
          className: 'zpin-wrap',
          html: '<div class="zpin" style="--vc:' + v.hex + '"><span class="zpin-dot"><b>' + v.n + '</b></span></div>',
          iconSize: [38, 48], iconAnchor: [19, 46], popupAnchor: [0, -42],
        });
        const m = L.marker([v.lat, v.lng], { icon }).addTo(map);
        m.bindPopup(
          '<div class="zpop"><span class="zpop-role" style="color:' + v.hex + '">' + v.icon + ' ' + v.role + '</span>' +
          '<strong>' + v.name + '</strong>' +
          '<a href="' + dirUrl(v.name) + '" target="_blank" rel="noopener">Itinéraire ↗</a></div>',
          { closeButton: false }
        );
        m.on('click', function () { select(i); });
        markers.push(m); pts.push([v.lat, v.lng]);
      });

      const bounds = L.latLngBounds(pts);

      function clearActive() {
        document.querySelectorAll('.zmap-card').forEach((c) => c.classList.remove('is-active'));
        document.querySelectorAll('.zpin-wrap').forEach((p) => p.classList.remove('is-active'));
      }
      function select(i) {
        clearActive();
        const v = venues[i];
        map.flyTo([v.lat, v.lng], 16, { duration: 0.8 });
        markers[i].openPopup();
        const card = document.querySelector('.zmap-card[data-i="' + i + '"]');
        if (card) card.classList.add('is-active');
        if (markers[i]._icon) markers[i]._icon.classList.add('is-active');
      }
      function overview() { clearActive(); map.flyToBounds(bounds, { padding: [50, 50], maxZoom: 15, duration: 0.8 }); }

      document.querySelectorAll('.zmap-card').forEach(function (card) {
        const i = parseInt(card.dataset.i, 10);
        card.addEventListener('click', function () { select(i); });
        card.addEventListener('mouseenter', function () { if (markers[i]._icon) markers[i]._icon.classList.add('is-hover'); });
        card.addEventListener('mouseleave', function () { if (markers[i]._icon) markers[i]._icon.classList.remove('is-hover'); });
      });
      const reset = document.getElementById('zmap-reset');
      if (reset) reset.addEventListener('click', overview);

      map.fitBounds(bounds, { padding: [50, 50], maxZoom: 15 });
      setTimeout(function () { map.invalidateSize(); }, 200);
    })();
  </script>
</Base>
