---
import Base from '../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../lib/strapi.js';

const res = await fetchAPI('press-resources', { populate: 'files', sort: 'order:asc', 'pagination[limit]': '50' });
const fallback = [
  { title: 'Dossier de presse', description: 'Présentation complète du festival, chiffres clés, axes de programmation et contacts.', category: 'PDF', files: [{ name: 'logo-ziffa.png', url: '/ziffa.png' }] },
  { title: 'Logos & charte graphique', description: 'Logos ZIFFA (couleur, blanc) et règles d’usage de la marque.', category: 'Logos', files: [{ name: 'logo-ziffa.png', url: '/ziffa.png' }] },
  { title: 'Photothèque officielle', description: 'Sélection de photos haute définition libres de droits pour la presse.', category: 'Photos', files: [{ name: 'logo-ziffa.png', url: '/ziffa.png' }] },
];
const cms = (res.data || []).map((r) => ({
  title: r.title, description: r.description || '', category: r.category || '',
  files: (r.files || []).map((f) => ({ name: f.name, url: mediaUrl(f.url) })),
}));
const resources = cms.length ? cms : fallback;
---
<Base title="Espace presse | ZIFFA" description="Espace presse du ZIFFA : dossier de presse, logos & charte graphique, photothèque officielle — à télécharger.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/">Accueil</a> &nbsp;/&nbsp; <a href="/le-ziffa#presse">Le ZIFFA</a> &nbsp;/&nbsp; Presse</div>
      <div class="eyebrow"><span class="arrow">→</span> Espace presse</div>
      <h1>Espace <span class="yellow">presse</span>.</h1>
      <p>Téléchargez les ressources officielles du ZIFFA : une par une, par sélection ou toutes en une fois.</p>
    </div>
  </header>

  <section class="section">
    <div class="press-toolbar">
      <label class="press-selectall"><input type="checkbox" id="press-all-cb" /> Tout sélectionner</label>
      <div class="press-toolbar-actions">
        <button type="button" class="btn-ghost" id="press-dl-selection" style="color:var(--green-deep);border-color:var(--line);">Télécharger la sélection</button>
        <button type="button" class="nav-cta" id="press-dl-all">Tout télécharger ↓</button>
      </div>
    </div>

    <div class="press-grid" id="press-grid">
      {resources.map((r, idx) => (
        <article class="press-card" data-idx={idx}>
          <label class="press-check"><input type="checkbox" class="press-cb" /></label>
          {r.category && <span class="press-cat">{r.category}</span>}
          <h3>{r.title}</h3>
          {r.description && <p>{r.description}</p>}
          <div class="press-files">
            {r.files.length === 0 && <span class="press-empty">Fichier à venir</span>}
            {r.files.map((f) => (
              <a class="press-file" href={f.url} download data-url={f.url} data-name={f.name}><span>📄 {f.name}</span><span class="press-file-dl">↓</span></a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</Base>

<script>
  const grid = document.getElementById('press-grid');
  if (grid) {
    const cards = Array.from(grid.querySelectorAll('.press-card'));
    const filesOf = (card) => Array.from(card.querySelectorAll('.press-file')).map((a) => ({ url: a.dataset.url, name: a.dataset.name }));

    // Téléchargements séquentiels (petit délai pour éviter le blocage navigateur).
    function downloadAll(files) {
      files.forEach((f, i) => setTimeout(() => {
        const a = document.createElement('a');
        a.href = f.url; a.download = f.name || ''; a.target = '_blank'; a.rel = 'noopener';
        document.body.appendChild(a); a.click(); a.remove();
      }, i * 400));
    }

    document.getElementById('press-all-cb')?.addEventListener('change', (e) => {
      cards.forEach((c) => { const cb = c.querySelector('.press-cb'); cb.checked = e.target.checked; c.classList.toggle('selected', e.target.checked); });
    });
    cards.forEach((c) => c.querySelector('.press-cb').addEventListener('change', (e) => c.classList.toggle('selected', e.target.checked)));

    document.getElementById('press-dl-selection')?.addEventListener('click', () => {
      const sel = cards.filter((c) => c.querySelector('.press-cb').checked);
      const files = sel.flatMap(filesOf);
      if (!files.length) { alert('Sélectionnez au moins une ressource.'); return; }
      downloadAll(files);
    });
    document.getElementById('press-dl-all')?.addEventListener('click', () => downloadAll(cards.flatMap(filesOf)));
  }
</script>
