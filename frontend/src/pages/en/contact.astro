---
import Base from '../../layouts/Base.astro';
import Socials from '../../components/Socials.astro';
---
<Base title="Contact | ZIFFA" description="Contact the ZIFFA team: programme, press, partnerships, submissions. Email, phone and newsletter.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; Contact</div>
      <div class="eyebrow"><span class="arrow">→</span> Get in touch</div>
      <h1>We'll <span class="yellow">reply</span>.</h1>
      <p>A question about the programme, press, partnerships or submissions? Write to us.</p>
    </div>
  </header>

  <section class="section" id="contact">
    <div class="contact-tiles">
      <a class="contact-tile ct-red" href="mailto:festival@ziffa.sn">
        <span class="ct-ic">✉️</span>
        <span class="ct-k">Email</span>
        <span class="ct-v">festival@ziffa.sn</span>
      </a>
      <div class="contact-tile ct-green">
        <span class="ct-ic">📞</span>
        <span class="ct-k">Phone</span>
        <span class="ct-v">XXXXXXXX</span>
      </div>
      <div class="contact-tile ct-yellow">
        <span class="ct-ic">📍</span>
        <span class="ct-k">Address</span>
        <span class="ct-v">Ziguinchor, Casamance — Senegal</span>
      </div>
    </div>

    <div class="contact-grid">
      <div class="contact-form-card">
        <h2 class="contact-form-title">Write to us</h2>
        <div id="ct-alert" class="form-alert"></div>
        <form id="ct-form" class="insc-form" novalidate>
          <div class="hp"><label>Do not fill<input type="text" name="website" tabindex="-1" autocomplete="off" /></label></div>
          <input type="hidden" name="type" value="contact" />
          <div class="grid2">
            <div class="field"><label>Name <span class="req">*</span></label><input type="text" name="name" required /></div>
            <div class="field"><label>Email <span class="req">*</span></label><input type="email" name="email" required /></div>
          </div>
          <div class="field"><label>Subject</label>
            <select name="subject"><option value="">— Choose —</option><option>Programme</option><option>Press</option><option>Partnerships</option><option>Submissions</option><option>Accreditation</option><option>Other</option></select>
          </div>
          <div class="field"><label>Message <span class="req">*</span></label><textarea name="message" required style="min-height:150px"></textarea></div>
          <button type="submit" class="submit-btn" id="ct-submit">Send message ↗</button>
        </form>
      </div>

      <aside class="contact-panel">
        <div class="eyebrow" style="color:var(--yellow);"><span class="arrow">→</span> Let's talk</div>
        <h3>Always happy<br />to hear from you.</h3>
        <p>Programme, press, partnerships, submissions… the ZIFFA team replies quickly, in English and French.</p>
        <div class="contact-panel-foot">
          <div class="contact-panel-label">Follow us</div>
          <Socials />
        </div>
      </aside>
    </div>
  </section>

  <section class="newsletter-section" id="newsletter">
    <div class="newsletter-box">
      <div class="eyebrow" style="justify-content:center;"><span class="arrow">→</span> Stay informed</div>
      <h2 class="section-title" style="margin:12px auto;">The <span class="yellow-highlight">newsletter</span>.</h2>
      <p>Programme, calls for films, accreditation: get ZIFFA announcements straight to your inbox.</p>
      <div id="nl-alert" class="form-alert"></div>
      <form id="nl-form" class="newsletter-form" novalidate>
        <div class="hp"><label>Do not fill<input type="text" name="website" tabindex="-1" autocomplete="off" /></label></div>
        <input type="hidden" name="type" value="newsletter" />
        <input type="email" name="email" placeholder="your@email.com" required />
        <button type="submit" class="nav-cta" id="nl-submit">Subscribe ↗</button>
      </form>
    </div>
  </section>

  <section class="section">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Find us</div><h2 class="section-title">In <span class="red">Ziguinchor</span>.</h2></div></div>
    <div class="contact-map">
      <iframe src="https://www.google.com/maps?q=Ziguinchor,+S%C3%A9n%C3%A9gal&z=13&output=embed" title="Map — Ziguinchor, Senegal" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
    </div>
  </section>
</Base>

<script>
  function wire(formId, alertId, submitId, okMsg) {
    const form = document.getElementById(formId);
    const alertBox = document.getElementById(alertId);
    const submitBtn = document.getElementById(submitId);
    if (!form) return;
    const show = (type, msg) => { alertBox.className = 'form-alert show ' + type; alertBox.textContent = msg; alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' }); };
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!form.checkValidity()) { show('err', 'Please fill in the required fields (*).'); return; }
      submitBtn.disabled = true; const original = submitBtn.textContent; submitBtn.textContent = 'Sending…';
      try {
        const res = await fetch('/api/contact-submission', { method: 'POST', body: new FormData(form) });
        const data = await res.json();
        if (data.ok) { show('ok', okMsg); form.reset(); }
        else { show('err', '⚠️ ' + (data.error || 'An error occurred.')); }
      } catch (err) { show('err', '⚠️ Submission failed. Check your connection and try again.'); }
      finally { submitBtn.disabled = false; submitBtn.textContent = original; }
    });
  }
  wire('ct-form', 'ct-alert', 'ct-submit', '✅ Thank you! Your message has been sent. We will reply by email.');
  wire('nl-form', 'nl-alert', 'nl-submit', '✅ Thank you! Your newsletter subscription is registered.');
</script>
