---
import Base from '../../layouts/Base.astro';
import { toVideoEmbed } from '../../lib/formations.js';

const films = [
  { title: 'Fanikendo', url: 'https://vimeo.com/1154101539' },
  { title: 'Aïcha', url: 'https://vimeo.com/1154100782' },
];
---
<Base title="Animation — ZIFFA" description="ZIFFA puts animated film in the spotlight: young-audience programming, Children's Cinema and films made in the stop-motion workshop.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; <a href="/en/a-lannee">Year-round</a> &nbsp;/&nbsp; Animation</div>
      <div class="eyebrow"><span class="arrow">→</span> Year-round · Animation</div>
      <h1><span class="yellow">Animation</span>.</h1>
      <p>ZIFFA puts animated film in the spotlight and opens young audiences to diverse stories.</p>
    </div>
  </header>

  <section class="section" id="presentation">
    <div class="presentation-editorial" style="max-width:880px;">
      <p>The animation programme featured <strong>11 films</strong> at the 2025 edition, highlighting African stories and singular voices — often beyond the reach of mainstream streaming platforms.</p>
      <p>Each screening comes with a discussion and activity, in partnership with the <strong>Regional Cultural Centre of Ziguinchor</strong> and local schools.</p>
    </div>
  </section>

  <section class="section" id="cine-enfants">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Young audiences</div><h2 class="section-title"><span class="red">Children's Cinema</span>.</h2></div></div>
    <div class="presentation-editorial" style="max-width:880px;margin-bottom:30px;">
      <p>A joyful, educational film club led by the festival team, built around films for children. In 2025, two sessions (12 and 13 November) gathered <strong>600 young viewers</strong> at the Regional Cultural Centre, including a screening of <strong><em>Sirocco and the Kingdom of the Winds</em></strong> by Benoît Chieux.</p>
    </div>
    <div class="objectifs-grid">
      <div class="objectif-card objectif-card--filled oc-red"><div class="objectif-num">— Audience</div><h3>600 children</h3><p>Across two dedicated sessions (ages 8–12).</p></div>
      <div class="objectif-card objectif-card--filled oc-green"><div class="objectif-num">— Venue</div><h3>Regional Cultural Centre</h3><p>Screenings and workshops for young audiences.</p></div>
      <div class="objectif-card objectif-card--filled oc-yellow"><div class="objectif-num">— Partner</div><h3>Arts for Kids</h3><p>Outreach and participant selection.</p></div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="films-atelier">
    <div class="section-head"><div><div class="eyebrow"><span class="arrow">→</span> Made at the festival</div><h2 class="section-title">The <span class="italic">workshop films</span>.</h2></div><a href="/en/formations/stop-motion" class="btn-ghost" style="color:var(--green-deep);border-color:var(--line);">The stop-motion workshop →</a></div>
    <p class="lead" style="max-width:760px;margin-bottom:24px;">Two animated films created frame by frame by the young people of the stop-motion residency:</p>
    <div class="formation-videos">
      {films.map((f) => (
        <div class="formation-video">
          <div class="video-wrapper"><iframe src={toVideoEmbed(f.url)} title={f.title} allow="fullscreen; picture-in-picture" allowfullscreen loading="lazy" style="width:100%;height:100%;border:0;display:block;"></iframe></div>
          <div class="formation-video-title">{f.title}</div>
        </div>
      ))}
    </div>
  </section>
</Base>
