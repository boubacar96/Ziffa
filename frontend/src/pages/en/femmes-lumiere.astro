---
import Base from '../../layouts/Base.astro';
import { fetchAPI, mediaUrl } from '../../lib/strapi.js';
import { fallbackFemmes } from '../../lib/femmes-lumiere.js';

const res = await fetchAPI('femmes-lumiere', { populate: 'cover', sort: 'order:asc', 'pagination[limit]': '50' });
const cms = (res.data || []).map((f) => ({ slug: f.slug, title: f.title, excerpt: f.excerpt || '', cover: f.cover?.url ? mediaUrl(f.cover.url) : null }));
const femmes = cms.length ? cms.filter((f) => f.slug) : fallbackFemmes('en');
---
<Base title="Women in the spotlight | ZIFFA" description="Women in the spotlight: portraits of directors, producers and artists who shape African cinema at ZIFFA.">
  <header class="page-hero">
    <div class="page-hero-inner">
      <div class="breadcrumb"><a href="/en">Home</a> &nbsp;/&nbsp; <a href="/en/a-lannee">Year-round</a> &nbsp;/&nbsp; Women in the spotlight</div>
      <div class="eyebrow"><span class="arrow">→</span> They make cinema</div>
      <h1>Women in the <span class="yellow">spotlight</span>.</h1>
      <p>Portraits of directors, producers and artists who make African cinema shine.</p>
    </div>
  </header>

  <section class="section">
    <div class="formations-grid">
      {femmes.map((f) => (
        <a class="formation-card" href={`/en/femmes-lumiere/${f.slug}`}>
          <div class="formation-cover" style={f.cover ? `background-image:url('${f.cover}')` : ''}></div>
          <div class="formation-body">
            <h3>{f.title}</h3>
            {f.excerpt && <p>{f.excerpt}</p>}
            <span class="formation-more">Read more →</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
